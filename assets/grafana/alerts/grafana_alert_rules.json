[
  {
    "uid": "workshop-5xx-share",
    "title": "High HTTP 5xx share",
    "ruleGroup": "workshop-http",
    "folderUID": "workshop",
    "condition": "C",
    "for": "5m",
    "noDataState": "OK",
    "execErrState": "Error",
    "isPaused": false,
    "labels": {
      "severity": "warning"
    },
    "annotations": {
      "summary": "5xx responses exceed a fraction of total HTTP traffic (workshop OTLP metrics)."
    },
    "data": [
      {
        "refId": "A",
        "datasourceUid": "prometheus",
        "relativeTimeRange": {
          "from": 300,
          "to": 0
        },
        "model": {
          "expr": "sum(rate(http_requests_total{http.response.status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m]))"
        }
      },
      {
        "refId": "B",
        "datasourceUid": "__expr__",
        "relativeTimeRange": {
          "from": 0,
          "to": 0
        },
        "model": {
          "type": "reduce",
          "reducer": "last"
        }
      },
      {
        "refId": "C",
        "datasourceUid": "__expr__",
        "relativeTimeRange": {
          "from": 0,
          "to": 0
        },
        "model": {
          "type": "threshold",
          "conditions": [
            {
              "evaluator": {
                "type": "gt",
                "params": [
                  0.15
                ]
              }
            }
          ]
        }
      }
    ]
  },
  {
    "uid": "workshop-operation-errors",
    "title": "Operation errors rate",
    "ruleGroup": "workshop-operations",
    "folderUID": "workshop",
    "condition": "C",
    "for": "5m",
    "noDataState": "OK",
    "execErrState": "Error",
    "isPaused": false,
    "labels": {
      "severity": "warning"
    },
    "annotations": {
      "summary": "Business operation_errors_total rate is elevated (workshop fleet)."
    },
    "data": [
      {
        "refId": "A",
        "datasourceUid": "prometheus",
        "relativeTimeRange": {
          "from": 300,
          "to": 0
        },
        "model": {
          "expr": "sum(rate(operation_errors_total[5m]))"
        }
      },
      {
        "refId": "B",
        "datasourceUid": "__expr__",
        "relativeTimeRange": {
          "from": 0,
          "to": 0
        },
        "model": {
          "type": "reduce",
          "reducer": "last"
        }
      },
      {
        "refId": "C",
        "datasourceUid": "__expr__",
        "relativeTimeRange": {
          "from": 0,
          "to": 0
        },
        "model": {
          "type": "threshold",
          "conditions": [
            {
              "evaluator": {
                "type": "gt",
                "params": [
                  0.5
                ]
              }
            }
          ]
        }
      }
    ]
  }
]
