{
  "title": "Error budget view",
  "description": "Synthetic Datadog-style export for migration workshop (multi-widget)",
  "widgets": [
    {
      "definition": {
        "type": "timeseries",
        "title": "HTTP errors total",
        "requests": [
          {
            "q": "sum:trace.http.request.errors{*}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "HTTP hits total",
        "requests": [
          {
            "q": "sum:trace.http.request.hits{*}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 0,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Errors by service",
        "requests": [
          {
            "q": "sum:trace.http.request.errors{*} by {service}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 4,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Errors by resource",
        "requests": [
          {
            "q": "sum:trace.http.request.errors{*} by {resource_name}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 4,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "5xx rate proxy",
        "requests": [
          {
            "q": "sum:trace.http.request.errors{*} by {http.status_code}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 8,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Client errors",
        "requests": [
          {
            "q": "sum:trace.http.client.errors{*} by {service}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 8,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Failed spans",
        "requests": [
          {
            "q": "sum:trace.spans.finished{*} by {service}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 12,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Error budget burn (hits)",
        "requests": [
          {
            "q": "sum:trace.http.request.hits{*} by {service}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 12,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Latency on errors",
        "requests": [
          {
            "q": "avg:trace.http.request.duration{*} by {service}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 16,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Apdex",
        "requests": [
          {
            "q": "avg:app.apdex.score{*} by {service}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 16,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Log-style error spike",
        "requests": [
          {
            "q": "sum:trace.http.request.errors{*} by {host}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 20,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Availability proxy \u2014 hits",
        "requests": [
          {
            "q": "sum:trace.http.request.hits{*} by {host}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 20,
        "width": 6,
        "height": 4
      }
    }
  ],
  "template_variables": [
    {
      "name": "env",
      "default": "*",
      "prefix": "env"
    }
  ]
}
