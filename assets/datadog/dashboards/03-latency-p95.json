{
  "title": "Latency p95",
  "description": "Synthetic Datadog-style export for migration workshop (multi-widget)",
  "widgets": [
    {
      "definition": {
        "type": "timeseries",
        "title": "p95 by resource",
        "requests": [
          {
            "q": "p95:trace.http.request.duration{*} by {resource_name}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "p99 by service",
        "requests": [
          {
            "q": "p99:trace.http.request.duration{*} by {service}",
