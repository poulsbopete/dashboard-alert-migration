{
  "title": "Service overview",
  "description": "Synthetic Datadog-style export for migration workshop (multi-widget)",
  "widgets": [
    {
      "definition": {
        "type": "timeseries",
        "title": "HTTP duration by service",
        "requests": [
          {
            "q": "avg:trace.http.request.duration{*} by {service}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "HTTP hits (count)",
        "requests": [
          {
            "q": "sum:trace.http.request.hits{*}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 0,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "HTTP errors",
        "requests": [
          {
            "q": "sum:trace.http.request.errors{*}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 4,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Duration p95 by resource",
        "requests": [
          {
            "q": "p95:trace.http.request.duration{*} by {resource_name}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 4,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Hits by resource",
        "requests": [
          {
            "q": "sum:trace.http.request.hits{*}.as_count() by {resource_name}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 8,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Apdex-style score",
        "requests": [
          {
            "q": "avg:app.apdex.score{*} by {service}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 8,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Client request duration",
        "requests": [
          {
            "q": "avg:trace.http.client.duration{*} by {service}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 12,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Servlet hits",
        "requests": [
          {
            "q": "sum:trace.servlet.request.hits{*}.as_count() by {service}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 12,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "RPC latency",
        "requests": [
          {
            "q": "avg:trace.grpc.client.duration{*} by {service}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 16,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "DB statement duration",
        "requests": [
          {
            "q": "avg:trace.postgres.query.duration{*} by {service}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 16,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "CPU user (host proxy)",
        "requests": [
          {
            "q": "avg:system.cpu.user{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 20,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Memory usable %",
        "requests": [
          {
            "q": "avg:system.mem.pct_usable{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 20,
        "width": 6,
        "height": 4
      }
    }
  ],
  "template_variables": [
    {
      "name": "env",
      "default": "*",
      "prefix": "env"
    }
  ]
}
