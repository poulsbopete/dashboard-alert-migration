{
  "title": "Network bytes",
  "description": "Synthetic Datadog-style export for migration workshop (multi-widget)",
  "widgets": [
    {
      "definition": {
        "type": "timeseries",
        "title": "Bytes sent rate",
        "requests": [
          {
            "q": "sum:system.net.bytes_sent{*} by {interface}.as_rate()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Bytes rcvd rate",
        "requests": [
          {
            "q": "sum:system.net.bytes_rcvd{*} by {interface}.as_rate()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 0,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "TCP retransmits",
        "requests": [
          {
            "q": "sum:system.net.tcp.retrans_segs{*} by {host}.as_rate()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 4,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "UDP errors",
        "requests": [
          {
            "q": "sum:system.net.udp.in_errors{*} by {host}.as_rate()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 4,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Packets in",
        "requests": [
          {
            "q": "sum:system.net.packets_in.count{*} by {interface}.as_rate()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 8,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Packets out",
        "requests": [
          {
            "q": "sum:system.net.packets_out.count{*} by {interface}.as_rate()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 8,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Connection count",
        "requests": [
          {
            "q": "avg:system.net.tcp.connections{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 12,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Listen overflows",
        "requests": [
          {
            "q": "sum:system.net.tcp.listen_overflows{*} by {host}.as_rate()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 12,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "HTTP traffic proxy",
        "requests": [
          {
            "q": "sum:trace.http.request.hits{*} by {service}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 16,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "DNS latency proxy",
        "requests": [
          {
            "q": "avg:trace.dns.lookup.duration{*} by {service}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 16,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Net errors in",
        "requests": [
          {
            "q": "sum:system.net.errors_in{*} by {interface}.as_rate()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 20,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Net errors out",
        "requests": [
          {
            "q": "sum:system.net.errors_out{*} by {interface}.as_rate()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 20,
        "width": 6,
        "height": 4
      }
    }
  ],
  "template_variables": [
    {
      "name": "env",
      "default": "*",
      "prefix": "env"
    }
  ]
}
