{
  "title": "Network bytes",
  "description": "Synthetic Datadog-style export for migration workshop",
  "widgets": [
    {
      "definition": {
        "type": "timeseries",
        "title": "Series A",
        "requests": [
          {
            "q": "sum:system.net.bytes_sent{*}.as_rate()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 12,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Series B",
        "requests": [
          {
            "q": "sum:system.net.bytes_rcvd{*}.as_rate()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 12,
        "height": 4
      }
    }
  ],
  "template_variables": [
    {
      "name": "env",
      "default": "*",
      "prefix": "env"
    }
  ]
}
