{
  "title": "Log error spike",
  "description": "Synthetic Datadog-style export for migration workshop (multi-widget)",
  "widgets": [
    {
      "definition": {
        "type": "timeseries",
        "title": "Errors by path",
        "requests": [
          {
            "q": "logs(\"status:error\").index(\"*\").rollup(\"count\").by(\"@http.url_details.path\")",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Errors by service",
        "requests": [
          {
            "q": "logs(\"status:error\").index(\"*\").rollup(\"count\").by(\"service\")",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 0,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "All levels by service",
        "requests": [
          {
            "q": "logs(\"*\").index(\"*\").rollup(\"count\").by(\"service\")",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 4,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Warn + error",
        "requests": [
          {
            "q": "logs(\"status:warn OR status:error\").index(\"*\").rollup(\"count\").by(\"service\")",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 4,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "By kube namespace",
        "requests": [
          {
            "q": "logs(\"*\").index(\"*\").rollup(\"count\").by(\"kube_namespace\")",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 8,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Security proxy",
        "requests": [
          {
            "q": "logs(\"source:security\").index(\"*\").rollup(\"count\").by(\"service\")",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 8,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Apache errors",
        "requests": [
          {
            "q": "logs(\"source:apache\").index(\"*\").rollup(\"count\").by(\"host\")",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 12,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Nginx access proxy",
        "requests": [
          {
            "q": "logs(\"source:nginx\").index(\"*\").rollup(\"count\").by(\"http.url\")",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 12,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Trace errors",
        "requests": [
          {
            "q": "sum:trace.http.request.errors{*} by {service}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 16,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "HTTP hits context",
        "requests": [
          {
            "q": "sum:trace.http.request.hits{*} by {service}.as_count()",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 16,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Duration during spikes",
        "requests": [
          {
            "q": "avg:trace.http.request.duration{*} by {service}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 20,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Disk IO proxy",
        "requests": [
          {
            "q": "avg:system.disk.io{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 20,
        "width": 6,
        "height": 4
      }
    }
  ],
  "template_variables": [
    {
      "name": "env",
      "default": "*",
      "prefix": "env"
    }
  ]
}
