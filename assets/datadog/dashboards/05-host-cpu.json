{
  "title": "Host CPU",
  "description": "Synthetic Datadog-style export for migration workshop (multi-widget)",
  "widgets": [
    {
      "definition": {
        "type": "timeseries",
        "title": "CPU user %",
        "requests": [
          {
            "q": "avg:system.cpu.user{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "CPU system %",
        "requests": [
          {
            "q": "avg:system.cpu.system{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 0,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "CPU idle %",
        "requests": [
          {
            "q": "avg:system.cpu.idle{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 4,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "CPU iowait %",
        "requests": [
          {
            "q": "avg:system.cpu.iowait{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 4,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Load avg 1m",
        "requests": [
          {
            "q": "avg:system.load.1{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 8,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Load avg 5m",
        "requests": [
          {
            "q": "avg:system.load.5{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 8,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Load avg 15m",
        "requests": [
          {
            "q": "avg:system.load.15{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 12,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "CPU steal",
        "requests": [
          {
            "q": "avg:system.cpu.stolen{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 12,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Nice CPU",
        "requests": [
          {
            "q": "avg:system.cpu.nice{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 16,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Guest CPU",
        "requests": [
          {
            "q": "avg:system.cpu.guest{*} by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 16,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Context switches",
        "requests": [
          {
            "q": "sum:system.cpu.context_switches{*}.as_rate() by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 20,
        "width": 6,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Interrupts",
        "requests": [
          {
            "q": "sum:system.cpu.interrupt{*}.as_rate() by {host}",
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 20,
        "width": 6,
        "height": 4
      }
    }
  ],
  "template_variables": [
    {
      "name": "env",
      "default": "*",
      "prefix": "env"
    }
  ]
}
