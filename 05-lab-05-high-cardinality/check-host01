#!/bin/bash
set -euo pipefail
export KUBECONFIG=/root/.kube/config
rep="$(kubectl get deployment cardinality-stress -n workshop-o11y -o jsonpath='{.spec.replicas}' 2>/dev/null || echo 0)"
if [ "${rep:-0}" != "1" ]; then
  fail-message "cardinality-stress should be scaled to 1 replica (currently: ${rep:-missing})."
fi
if ! kubectl get configmap alloy-config -n workshop-o11y -o yaml | grep -q "cardinality-stress"; then
  fail-message "Alloy config should scrape cardinality-stress (see k8s/lab05/alloy-with-cardinality.river)."
fi
