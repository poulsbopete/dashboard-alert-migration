  XYReferenceLine:
    additionalProperties: false
    description: "Configuration for a single reference line in an XY chart.\n\nInherits from BaseIdentifiableModel for automatic deterministic ID generation."
    properties:
      axis:
        anyOf[2]:
          - enum[2]: left,right
            type: string
          - type: "null"
        default: left
        description: The axis to assign the reference line to.
        title: Axis
      color:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: The color of the reference line.
        title: Color
      fill:
        anyOf[2]:
          - enum[3]: above,below,none
            type: string
          - type: "null"
        default: null
        description: Fill area above or below the line.
        title: Fill
      icon:
        anyOf[2]:
          - "$ref": #/$defs/ReferenceLineIcon
          - type: "null"
        default: null
        description: Icon to display on the reference line.
      icon_position:
        anyOf[2]:
          - enum[5]: above,auto,below,left,right
            type: string
          - type: "null"
        default: null
        description: Position of the icon on the reference line.
        title: Icon Position
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Optional label for the reference line.
        title: Label
      line_style:
        anyOf[2]:
          - enum[3]: dashed,dotted,solid
            type: string
          - type: "null"
        default: null
        description: The style of the reference line.
        title: Line Style
      line_width:
        anyOf[2]:
          - maximum: 10
            minimum: 1
            type: integer
          - type: "null"
        default: null
        description: The width of the reference line (1-10).
        title: Line Width
      value:
        anyOf[2]:
          - "$ref": #/$defs/XYReferenceLineValue
          - type: number
        description: The value for the reference line. Can be a float or XYReferenceLineValue object.
        title: Value
    required[1]: value
    title: XYReferenceLine
    type: object
  XYReferenceLineValue:
    additionalProperties: false
    description: Defines the value for a reference line.
    properties:
      type:
        const: static
        default: static
        description: The type of value (always 'static' for now).
        title: Type
        type: string
      value:
        description: The static value for the reference line.
        title: Value
        type: number
    required[1]: value
    title: XYReferenceLineValue
    type: object
  XYValuesConfig:
    additionalProperties: false
    description: Formatting options for value labels on data points.
    properties:
      visible:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "Controls whether value labels are shown on data points (e.g., on top of bars). Kibana defaults to hidden if not specified."
        title: Visible
    title: XYValuesConfig
    type: object
additionalProperties: true
description: "Root configuration model for loading dashboards from YAML.\n\nNote: extra='allow' is needed to support YAML anchors (e.g., .base_query: &anchor)\nwhich get parsed as root-level keys but are ignored after anchor resolution."
properties:
  dashboards:
    description: List of dashboard configurations.
    items:
      "$ref": #/$defs/Dashboard
    title: Dashboards
    type: array
required[1]: dashboards
title: DashboardConfig
type: object