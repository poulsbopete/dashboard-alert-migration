"$defs":
  AndFilter:
    additionalProperties: false
    description: "Represents an 'and' filter configuration in the Config schema.\n\nThis filter matches documents that satisfy all of the specified filters."
    properties:
      alias:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "An optional alias for the filter, used for display purposes."
        title: Alias
      and:
        description: A list of filters. All filters must match for a document to be included.
        items:
          "$ref": #/$defs/FilterTypes
        title: And
        type: array
      disabled:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "Indicates whether the filter is disabled. If `true`, the filter will not be applied."
        title: Disabled
    required[1]: and
    title: AndFilter
    type: object
  AreaChartAppearance:
    additionalProperties: false
    description: Represents area chart appearance formatting options.
    properties:
      end_values:
        anyOf[2]:
          - enum[3]: nearest,none,zero
            type: string
          - type: "null"
        default: null
        description: How to handle the end of the time range in line/area charts.
        title: End Values
      fill_opacity:
        anyOf[2]:
          - maximum: 1
            minimum: 0
            type: number
          - type: "null"
        default: null
        description: The fill opacity for area charts (0.0 to 1.0).
        title: Fill Opacity
      hide_endzones:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to hide end zones in time series charts (areas where data is incomplete).
        title: Hide Endzones
      line_style:
        anyOf[2]:
          - enum[3]: linear,monotone-x,step-after
            type: string
          - type: "null"
        default: null
        description: "The line style for line/area charts. Only 3 types are supported by Kibana: linear (straight), monotone-x (smooth), step-after (stepped)."
        title: Line Style
      missing_values:
        anyOf[2]:
          - enum[6]: average,carry,linear,lookahead,nearest,none
            type: string
          - type: "null"
        default: null
        description: How to handle missing data points. Controls interpolation for gaps in your data.
        title: Missing Values
      show_as_dotted:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, visually distinguish interpolated data from real data points. Defaults to `false`."
        title: Show As Dotted
      show_current_time_marker:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to show a vertical line at the current time in time series charts.
        title: Show Current Time Marker
      values:
        anyOf[2]:
          - "$ref": #/$defs/XYValuesConfig
          - type: "null"
        default: null
        description: Formatting options for value labels on data points.
      x_axis:
        anyOf[2]:
          - "$ref": #/$defs/AxisConfig
          - type: "null"
        default: null
        description: Configuration for the X-axis.
      y_left_axis:
        anyOf[2]:
          - "$ref": #/$defs/AxisConfig
          - type: "null"
        default: null
        description: Configuration for the left Y-axis.
      y_right_axis:
        anyOf[2]:
          - "$ref": #/$defs/AxisConfig
          - type: "null"
        default: null
        description: Configuration for the right Y-axis.
    title: AreaChartAppearance
    type: object
  AxisConfig:
    additionalProperties: false
    description: Represents configuration for a single axis in XY charts.
    properties:
      extent:
        anyOf[2]:
          - "$ref": #/$defs/AxisExtent
          - type: "null"
        default: null
        description: Extent/bounds configuration for the axis.
      scale:
        anyOf[2]:
          - enum[4]: linear,log,sqrt,time
            type: string
          - type: "null"
        default: null
        description: Scale type for the axis. Defaults to 'linear'.
        title: Scale
      title:
        anyOf[3]{type}:
          boolean
          string
          "null"
        default: null
        description: "Axis title mode/value: True=auto, False=hidden, string=custom title."
        title: Title
    title: AxisConfig
    type: object
  AxisExtent:
    additionalProperties: false
    description: "Represents axis extent (bounds) configuration for XY chart axes.\n\nControls the range of values displayed on an axis. Can be set to:\n- 'full': Use the full extent of the data\n- 'custom': Specify custom bounds with min/max values\n- 'data_bounds': Fit to the actual data bounds"
    properties:
      enforce:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to enforce the bounds strictly. Defaults to false.
        title: Enforce
      max:
        anyOf[2]{type}:
          number
          "null"
        default: null
        description: Maximum value for the axis (only used when mode is 'custom').
        title: Max
      min:
        anyOf[2]{type}:
          number
          "null"
        default: null
        description: Minimum value for the axis (only used when mode is 'custom').
        title: Min
      mode:
        default: full
        description: The extent mode for the axis. Defaults to 'full'.
        enum[3]: custom,data_bounds,full
        title: Mode
        type: string
      nice_values:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to use nice rounded values for bounds. Defaults to true.
        title: Nice Values
    title: AxisExtent
    type: object
  BarChartAppearance:
    additionalProperties: false
    description: "Represents bar chart appearance formatting options.\n\nExtends BaseXYChartAppearance to include bar-specific options."
    properties:
      min_bar_height:
        anyOf[2]{type}:
          number
          "null"
        default: null
        description: The minimum height for bars in bar charts.
        title: Min Bar Height
      values:
        anyOf[2]:
          - "$ref": #/$defs/XYValuesConfig
          - type: "null"
        default: null
        description: Formatting options for value labels on data points.
      x_axis:
        anyOf[2]:
          - "$ref": #/$defs/AxisConfig
          - type: "null"
        default: null
        description: Configuration for the X-axis.
      y_left_axis:
        anyOf[2]:
          - "$ref": #/$defs/AxisConfig
          - type: "null"
        default: null
        description: Configuration for the left Y-axis.
      y_right_axis:
        anyOf[2]:
          - "$ref": #/$defs/AxisConfig
          - type: "null"
        default: null
        description: Configuration for the right Y-axis.
    title: BarChartAppearance
    type: object
  CollapseAggregationEnum:
    description: The aggregation to use for the dimension.
    enum[4]: avg,max,min,sum
    title: CollapseAggregationEnum
    type: string
  CollapsiblePanel:
    additionalProperties: false
    description: "A collapsible section that groups panels under a named, expandable header.\n\nIn the outer dashboard grid, a collapsible panel occupies a single full-width row\n(the section header). Its inner panels are laid out in a separate coordinate space\nrelative to the section.\n\nExamples:\n    ```yaml\n    dashboards:\n      - name: \"Dashboard with Sections\"\n        panels:\n          - title: \"Overview\"\n            size: { w: 48, h: 6 }\n            markdown:\n              content: \"# Overview\"\n          - title: \"Details\"\n            section:\n              collapsed: true\n              panels:\n                - title: \"CPU Usage\"\n                  size: { w: 48, h: 12 }\n                  markdown:\n                    content: \"# CPU\"\n    ```"
    properties:
      description:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: A brief description of the panel's content or purpose. Defaults to an empty string.
        title: Description
      drilldowns:
        anyOf[2]:
          - items:
              "$ref": #/$defs/DrilldownTypes
            type: array
          - type: "null"
        default: null
        description: Optional list of drilldowns to attach to this panel.
        title: Drilldowns
      hide_title:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, the panel title will be hidden. Defaults to `false` (title is shown)."
        title: Hide Title
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier for the panel. If not provided, one may be generated during compilation."
        title: Id
      position:
        "$ref": #/$defs/Position
        description: "Defines the panel's position on the dashboard grid. If not specified, position will be auto-calculated."
      section:
        "$ref": #/$defs/SectionConfig
        description: Section configuration including collapsed state and inner panels.
      size:
        "$ref": #/$defs/Size
        description: Section header size. Defaults to full width (48) and 1 row tall.
      title:
        default: ""
        description: The title displayed on the panel header. Can be an empty string.
        title: Title
        type: string
    required[1]: section
    title: CollapsiblePanel
    type: object
  ColorRangeMapping:
    additionalProperties: false
    description: Range/threshold-based color mapping for numeric values.
    properties:
      range_max:
        anyOf[2]{type}:
          number
          "null"
        default: null
        description: Optional upper bound for the palette domain. Use null for auto/open upper bound.
        title: Range Max
      range_min:
        anyOf[2]{type}:
          number
          "null"
        default: 0
        description: Optional lower bound for the palette domain. Use null for auto/open lower bound.
        title: Range Min
      range_type:
        default: number
        description: How threshold values are interpreted by Kibana.
        enum[2]: number,percent
        title: Range Type
        type: string
      thresholds:
        description: Ordered threshold bands used to build gauge-style color palettes.
        items:
          "$ref": #/$defs/ColorThreshold
        minItems: 1
        title: Thresholds
        type: array
    required[1]: thresholds
    title: ColorRangeMapping
    type: object
  ColorThreshold:
    additionalProperties: false
    description: Single threshold band in a range-based color map.
    properties:
      color:
        description: The color applied within this threshold band (hex color code).
        title: Color
        type: string
      up_to:
        description: Upper bound for this threshold band.
        title: Up To
        type: number
    required[2]: up_to,color
    title: ColorThreshold
    type: object
  ColorValueAssignment:
    additionalProperties: false
    description: Manual color assignment to specific categorical values.
    properties:
      color:
        description: "The hex color code to assign (e.g., '#FF0000')."
        title: Color
        type: string
      value:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: A single category value to assign a color to.
        title: Value
      values:
        anyOf[2]:
          - items:
              type: string
            type: array
          - type: "null"
        default: null
        description: Multiple category values to assign the same color to.
        title: Values
    required[1]: color
    title: ColorValueAssignment
    type: object
  ColorValueMapping:
    additionalProperties: false
    description: Categorical color mapping for charts keyed by exact values.
    properties:
      assignments:
        description: Manual color assignments to specific data values.
        items:
          "$ref": #/$defs/ColorValueAssignment
        title: Assignments
        type: array
      palette:
        default: eui_amsterdam_color_blind
        description: "The palette ID to use for unassigned colors.\n\nAvailable palettes:\n- 'default' - Standard EUI palette\n- 'eui_amsterdam_color_blind' - Color-blind safe palette (default)\n- 'kibana_palette' or 'legacy' - Legacy Kibana colors\n- 'elastic_brand' - Elastic brand colors\n- 'gray' - Grayscale palette"
        title: Palette
        type: string
    title: ColorValueMapping
    type: object
  ControlSettings:
    additionalProperties: false
    description: "Settings for controls in a dashboard, defining their behavior and appearance."
    properties:
      apply_global_filters:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to apply global filters to the control. Defaults to true if not set.
        title: Apply Global Filters
      apply_global_timerange:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to apply the global time range to the control. Defaults to true if not set.
        title: Apply Global Timerange
      chain_controls:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "Whether to chain controls together, allowing one control's selection to filter the next. Defaults to true if not set."
        title: Chain Controls
      click_to_apply:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to require users to click the apply button before applying changes. Defaults to false if not set.
        title: Click To Apply
      ignore_zero_results:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to ignore controls that return zero results. Defaults to true if not set.
        title: Ignore Zero Results
      label_position:
        anyOf[2]:
          - enum[2]: above,inline
            type: string
          - type: "null"
        default: null
        description: "The position of the control label, either 'inline' or 'above'. Defaults to 'inline' if not set."
        title: Label Position
    title: ControlSettings
    type: object
  ControlTypes:
    anyOf[9]{"$ref"}:
      #/$defs/RangeSliderControl
      #/$defs/OptionsListControl
      #/$defs/TimeSliderControl
      #/$defs/ESQLFieldControl
      #/$defs/ESQLFunctionControl
      #/$defs/ESQLStaticSingleSelectControl
      #/$defs/ESQLStaticMultiSelectControl
      #/$defs/ESQLQuerySingleSelectControl
      #/$defs/ESQLQueryMultiSelectControl
  CustomFilter:
    additionalProperties: false
    description: "Represents a custom filter configuration in the Config schema.\n\nThis filter allows for custom query definitions that do not fit into the standard filters."
    properties:
      alias:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "An optional alias for the filter, used for display purposes."
        title: Alias
      disabled:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "Indicates whether the filter is disabled. If `true`, the filter will not be applied."
        title: Disabled
      dsl:
        additionalProperties: true
        description: The custom query definition. This should be a valid Elasticsearch query object.
        title: Dsl
        type: object
    required[1]: dsl
    title: CustomFilter
    type: object
  Dashboard:
    additionalProperties: false
    description: "A dashboard with filters, controls, panels and more."
    properties:
      controls:
        description: A list of Controls for the dashboard.
        items:
          "$ref": #/$defs/ControlTypes
        title: Controls
        type: array
      description:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: A brief description of the dashboard's purpose or content.
        title: Description
      filters:
        description: A list of filters applied to the dashboard.
        items:
          "$ref": #/$defs/FilterTypes
        title: Filters
        type: array
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "An optional unique identifier for the dashboard, useful for giving the generated dashboard a specific ID."
        title: Id
      minimum_kibana_version:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "Optional minimum Kibana version required for this dashboard (e.g., '9.2.0')."
        title: Minimum Kibana Version
      name:
        description: The name of the dashboard.
        title: Name
        type: string
      panels:
        description: A list of Panels defining the content and layout of the dashboard.
        items:
          "$ref": #/$defs/DashboardPanelTypes
        title: Panels
        type: array
      query:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A query (KQL or Lucene) applied to the dashboard.
      sample_data:
        anyOf[2]:
          - "$ref": #/$defs/SampleData
          - type: "null"
        default: null
        description: Optional sample data to bundle with the dashboard for testing and demonstration.
      settings:
        "$ref": #/$defs/DashboardSettings
      time_range:
        anyOf[2]:
          - "$ref": #/$defs/TimeRange
          - type: "null"
        default: null
        description: A default time range to apply when opening the dashboard.
    required[1]: name
    title: Dashboard
    type: object
  DashboardDrilldown:
    additionalProperties: false
    description: Dashboard-to-dashboard drilldown configuration.
    properties:
      dashboard:
        description: Target dashboard ID or friendly identifier.
        title: Dashboard
        type: string
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "Optional unique identifier for the drilldown. If not provided, one will be generated."
        title: Id
      name:
        description: Display name for the drilldown.
        title: Name
        type: string
      triggers:
        description: "List of triggers that activate this drilldown. Defaults to ['click']."
        items:
          "$ref": #/$defs/DrilldownTrigger
        title: Triggers
        type: array
      with_filters:
        default: true
        description: Whether to carry over current filters to the target dashboard. Defaults to True.
        title: With Filters
        type: boolean
      with_time:
        default: true
        description: Whether to carry over current time range to the target dashboard. Defaults to True.
        title: With Time
        type: boolean
    required[2]: name,dashboard
    title: DashboardDrilldown
    type: object
  DashboardLink:
    additionalProperties: false
    description: Represents a link to another dashboard within a Links panel.
    properties:
      dashboard:
        description: The ID of the dashboard that the link points to.
        title: Dashboard
        type: string
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: An optional unique identifier for the link. Not normally required.
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: The text that will be displayed for the link. Kibana defaults to showing the URL if not set.
        title: Label
      new_tab:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, links will open in a new browser tab. Kibana defaults to `false` if not set."
        title: New Tab
      with_filters:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, the links will inherit the filters from the dashboard. Kibana defaults to `True` if not set."
        title: With Filters
      with_time:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, the links will inherit the time range from the dashboard. Kibana defaults to `True` if not set."
        title: With Time
    required[1]: dashboard
    title: DashboardLink
    type: object
  DashboardPanelTypes:
    oneOf[8]{"$ref"}:
      #/$defs/MarkdownPanel
      #/$defs/SearchPanel
      #/$defs/LinksPanel
      #/$defs/ImagePanel
      #/$defs/LensPanel
      #/$defs/ESQLPanel
      #/$defs/VegaPanel
      #/$defs/CollapsiblePanel
  DashboardSettings:
    additionalProperties: false
    description: "Global settings for a dashboard with options for margins, synchronization of colors."
    properties:
      controls:
        "$ref": #/$defs/ControlSettings
      layout_algorithm:
        default: up-left
        description: The auto-layout algorithm to use for positioning panels without explicit coordinates. Defaults to 'up-left'.
        enum[4]: blocked,first-available-gap,left-right,up-left
        title: Layout Algorithm
        type: string
      margins:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to put space between panels in the dashboard. Defaults to true if not set.
        title: Margins
      sync:
        "$ref": #/$defs/DashboardSyncSettings
      titles:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to display the titles in the panel headers. Defaults to true if not set.
        title: Titles
    title: DashboardSettings
    type: object
  DashboardSyncSettings:
    additionalProperties: false
    description: "Configure whether cursor, tooltips, and colors should sync across panels."
    properties:
      colors:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to apply the same color palette to all panels on the dashboard. Defaults to false if not set.
        title: Colors
      cursor:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to synchronize the cursor across related panels. Defaults to true if not set.
        title: Cursor
      tooltips:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to synchronize tooltips across related panels. Defaults to false if not set.
        title: Tooltips
    title: DashboardSyncSettings
    type: object
  DatatableAlignmentEnum:
    description: Alignment options for datatable columns.
    enum[3]: center,left,right
    title: DatatableAlignmentEnum
    type: string
  DatatableAppearance:
    additionalProperties: false
    description: Appearance settings for datatable visualization.
    properties:
      density:
        "$ref": #/$defs/DatatableDensityEnum
        default: normal
        description: Grid density setting.
      header_row_height:
        "$ref": #/$defs/DatatableRowHeightEnum
        default: auto
        description: Header row height mode.
      header_row_height_lines:
        anyOf[2]{type}:
          integer
          "null"
        default: null
        description: Number of lines for custom header row height (only used with header_row_height='custom').
        title: Header Row Height Lines
      row_height:
        "$ref": #/$defs/DatatableRowHeightEnum
        default: auto
        description: Row height mode.
      row_height_lines:
        anyOf[2]{type}:
          integer
          "null"
        default: null
        description: Number of lines for custom row height (only used with row_height='custom').
        title: Row Height Lines
    title: DatatableAppearance
    type: object
  DatatableColorModeEnum:
    description: Color mode options for datatable columns.
    enum[3]: cell,none,text
    title: DatatableColorModeEnum
    type: string
  DatatableColumnAppearance:
    additionalProperties: false
    description: Appearance options shared by datatable metric and dimension columns.
    properties:
      alignment:
        anyOf[2]:
          - "$ref": #/$defs/DatatableAlignmentEnum
          - type: "null"
        default: null
        description: Text alignment for the column.
      hidden:
        default: false
        description: Whether to hide this column.
        title: Hidden
        type: boolean
      one_click_filter:
        default: false
        description: Enable one-click filtering for this column.
        title: One Click Filter
        type: boolean
      width:
        anyOf[2]{type}:
          integer
          "null"
        default: null
        description: Column width in pixels.
        title: Width
    title: DatatableColumnAppearance
    type: object
  DatatableDensityEnum:
    description: Density options for datatable.
    enum[3]: compact,expanded,normal
    title: DatatableDensityEnum
    type: string
  DatatableLensCountAggregatedMetric:
    additionalProperties: false
    description: Datatable count metric with appearance options.
    properties:
      aggregation:
        default: count
        enum[2]: count,unique_count
        title: Aggregation
        type: string
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/DatatableMetricAppearance
          - type: "null"
        default: null
        description: "Presentation options for this metric (width, alignment, summary row, etc.)."
      color:
        anyOf[2]:
          - "$ref": #/$defs/DatatableMetricColor
          - type: "null"
        default: null
        description: Color display mode and optional range mapping for this metric.
      exclude_zeros:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to exclude zero values from the count. Kibana defaults to true if not specified.
        title: Exclude Zeros
      field:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The field to count. If not provided, the count will be of all documents in the data view."
        title: Field
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
    title: DatatableLensCountAggregatedMetric
    type: object
  DatatableLensDateHistogramBreakdown:
    additionalProperties: false
    description: Datatable date-histogram breakdown with appearance options and collapse support.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/DatatableColumnAppearance
          - type: "null"
        default: null
        description: Presentation options for this dimension.
      collapse:
        anyOf[2]:
          - "$ref": #/$defs/CollapseAggregationEnum
          - type: "null"
        default: null
        description: "Aggregate all breakdown values into a single bucket using this function (sum, avg, min, max)."
      field:
        description: The name of the field in the data view that this dimension is based on.
        title: Field
        type: string
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
