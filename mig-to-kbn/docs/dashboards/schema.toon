    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/HeatmapAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorRangeMapping
          - type: "null"
        default: null
        description: Optional range-based palette configuration for heatmap cell coloring.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      metric:
        "$ref": #/$defs/ESQLMetricTypes
        description: The metric that determines cell color intensity.
      query:
        "$ref": #/$defs/ESQLQueryTypes
        description: The ES|QL query to execute.
      time_field:
        default: @timestamp
        description: The time field to use for the dashboard time picker. Defaults to '@timestamp'.
        title: Time Field
        type: string
      type:
        const: heatmap
        default: heatmap
        description: "The type of chart, which is 'heatmap' for this visualization."
        title: Type
        type: string
      x_axis:
        "$ref": #/$defs/ESQLDimensionTypes
        description: The dimension to display on the X-axis (horizontal).
      y_axis:
        anyOf[2]:
          - "$ref": #/$defs/ESQLDimensionTypes
          - type: "null"
        default: null
        description: The dimension to display on the Y-axis (vertical). Optional for 1D heatmaps.
    required[3]: query,x_axis,metric
    title: ESQLHeatmapPanelConfig
    type: object
  ESQLLinePanelConfig:
    additionalProperties: false
    description: Configuration for an ES|QL line panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/LineChartAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/ESQLBreakdownTypes
          - type: "null"
        default: null
        description: "An optional dimension to split the series by. If provided, it will be used to break down the data into multiple series."
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color palette.
      dimension:
        anyOf[2]:
          - "$ref": #/$defs/ESQLDimensionTypes
          - type: "null"
        default: null
        description: Defines the X-axis dimension for the chart. XY charts support 0 or 1 dimension.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      legend:
        anyOf[2]:
          - "$ref": #/$defs/XYLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metrics:
        description: Defines the metrics for the chart. At least one metric is required.
        items:
          "$ref": #/$defs/ESQLXYMetricTypes
        minItems: 1
        title: Metrics
        type: array
      query:
        "$ref": #/$defs/ESQLQueryTypes
        description: The ES|QL query to execute.
      time_field:
        default: @timestamp
        description: The time field to use for the dashboard time picker. Defaults to '@timestamp'.
        title: Time Field
        type: string
      type:
        const: line
        default: line
        description: The type of XY chart to display. Defaults to 'line'.
        title: Type
        type: string
    required[2]: query,metrics
    title: ESQLLinePanelConfig
    type: object
  ESQLMetric:
    additionalProperties: false
    description: A metric that is defined in the ESQL query.
    properties:
      field:
        description: The field in the data view that this metric is based on.
        title: Field
        type: string
      format:
        anyOf[2]:
          - "$ref": #/$defs/ESQLMetricFormatTypes
          - type: "null"
        default: null
        description: "The format of the metric (number, bytes, bits, percent, duration, or custom)."
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Optional display label for the metric.
        title: Label
    required[1]: field
    title: ESQLMetric
    type: object
  ESQLMetricChartMetricTypes:
    additionalProperties: false
    description: Metric chart ES|QL metric with color options.
    properties:
      color:
        anyOf[2]:
          - "$ref": #/$defs/MetricChartColor
          - type: "null"
        default: null
        description: Color range mapping and application mode for this metric.
      field:
        description: The field in the data view that this metric is based on.
        title: Field
        type: string
      format:
        anyOf[2]:
          - "$ref": #/$defs/ESQLMetricFormatTypes
          - type: "null"
        default: null
        description: "The format of the metric (number, bytes, bits, percent, duration, or custom)."
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Optional display label for the metric.
        title: Label
    required[1]: field
    title: MetricESQLMetric
    type: object
  ESQLMetricFormat:
    additionalProperties: false
    description: "The format configuration for ES|QL metrics.\n\nSupports standard format types like number, bytes, bits, percent, and duration.\nThis is separate from LensMetricFormat as ES|QL and Lens formatting may diverge in the future."
    properties:
      compact:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to display the number in a compact format.
        title: Compact
      decimals:
        anyOf[2]{type}:
          integer
          "null"
        default: null
        description: "The number of decimal places to display. If not specified, defaults to 2 for number/bytes/percent/duration, 0 for bits."
        title: Decimals
      pattern:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: The pattern to display the number in.
        title: Pattern
      suffix:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: The suffix to display after the number.
        title: Suffix
      type:
        enum[5]: bits,bytes,duration,number,percent
        title: Type
        type: string
    required[1]: type
    title: ESQLMetricFormat
    type: object
  ESQLMetricFormatTypes:
    anyOf[2]{"$ref"}:
      #/$defs/ESQLMetricFormat
      #/$defs/ESQLCustomMetricFormat
  ESQLMetricPanelConfig:
    additionalProperties: false
    description: Configuration for an ES|QL metric panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/MetricAppearance
          - type: "null"
        default: null
        description: Visual appearance configuration for the metric.
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/ESQLBreakdownTypes
          - type: "null"
        default: null
        description: An optional breakdown dimension to split metric values by category.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      maximum:
        anyOf[2]:
          - "$ref": #/$defs/ESQLMetricTypes
          - type: "null"
        default: null
        description: "An optional maximum metric to display, often used for comparison or thresholds."
      primary:
        "$ref": #/$defs/ESQLMetricChartMetricTypes
        description: The primary metric to display in the chart. This is the main value shown in the metric visualization.
      query:
        "$ref": #/$defs/ESQLQueryTypes
        description: The ES|QL query to execute.
      secondary:
        anyOf[2]:
          - "$ref": #/$defs/ESQLMetricChartMetricTypes
          - type: "null"
        default: null
        description: An optional secondary metric to display alongside the primary metric.
      time_field:
        default: @timestamp
        description: The time field to use for the dashboard time picker. Defaults to '@timestamp'.
        title: Time Field
        type: string
      titles_and_text:
        anyOf[2]:
          - "$ref": #/$defs/MetricTitlesAndText
          - type: "null"
        default: null
        description: Formatting options for the chart titles and text.
      type:
        const: metric
        default: metric
        description: "The type of chart, which is 'metric' for this visualization."
        title: Type
        type: string
    required[2]: query,primary
    title: ESQLMetricPanelConfig
    type: object
  ESQLMetricTypes:
    additionalProperties: false
    description: A metric that is defined in the ESQL query.
    properties:
      field:
        description: The field in the data view that this metric is based on.
        title: Field
        type: string
      format:
        anyOf[2]:
          - "$ref": #/$defs/ESQLMetricFormatTypes
          - type: "null"
        default: null
        description: "The format of the metric (number, bytes, bits, percent, duration, or custom)."
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Optional display label for the metric.
        title: Label
    required[1]: field
    title: ESQLMetric
    type: object
  ESQLMosaicPanelConfig:
    additionalProperties: false
    description: Configuration for an ES|QL mosaic panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/MosaicAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/ESQLBreakdownTypes
          - type: "null"
        default: null
        description: Optional secondary breakdown for splitting the mosaic into sub-groups.
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color.
      dimension:
        "$ref": #/$defs/ESQLDimensionTypes
        description: Primary dimension for grouping data. Mosaic charts support only one dimension.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      legend:
        anyOf[2]:
          - "$ref": #/$defs/MosaicLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metric:
        "$ref": #/$defs/ESQLMetricTypes
        description: Metric that determines the size of rectangles. Mosaic charts support only one metric.
      query:
        "$ref": #/$defs/ESQLQueryTypes
        description: The ES|QL query to execute.
      time_field:
        default: @timestamp
        description: The time field to use for the dashboard time picker. Defaults to '@timestamp'.
        title: Time Field
        type: string
      type:
        const: mosaic
        default: mosaic
        title: Type
        type: string
    required[3]: query,metric,dimension
    title: ESQLMosaicPanelConfig
    type: object
  ESQLPanel:
    additionalProperties: false
    description: "Represents an ES|QL chart panel.\n\nThe esql field contains a discriminated union of ES|QL chart panel configurations.\nThe chart type is determined by the 'type' field."
    properties:
      description:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: A brief description of the panel's content or purpose. Defaults to an empty string.
        title: Description
      drilldowns:
        anyOf[2]:
          - items:
              "$ref": #/$defs/DrilldownTypes
            type: array
          - type: "null"
        default: null
        description: Optional list of drilldowns to attach to this panel.
        title: Drilldowns
      esql:
        "$ref": #/$defs/ESQLPanelConfig
        description: ES|QL panel configuration.
      hide_title:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, the panel title will be hidden. Defaults to `false` (title is shown)."
        title: Hide Title
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier for the panel. If not provided, one may be generated during compilation."
        title: Id
      position:
        "$ref": #/$defs/Position
        description: "Defines the panel's position on the dashboard grid. If not specified, position will be auto-calculated."
      size:
        "$ref": #/$defs/Size
        description: Defines the panel's size on the dashboard grid.
      title:
        default: ""
        description: The title displayed on the panel header. Can be an empty string.
        title: Title
        type: string
    required[1]: esql
    title: ESQLPanel
    type: object
  ESQLPanelConfig:
    discriminator:
      mapping:
        area: #/$defs/ESQLAreaPanelConfig
        bar: #/$defs/ESQLBarPanelConfig
        datatable: #/$defs/ESQLDatatablePanelConfig
        gauge: #/$defs/ESQLGaugePanelConfig
        heatmap: #/$defs/ESQLHeatmapPanelConfig
        line: #/$defs/ESQLLinePanelConfig
        metric: #/$defs/ESQLMetricPanelConfig
        mosaic: #/$defs/ESQLMosaicPanelConfig
        pie: #/$defs/ESQLPiePanelConfig
        tagcloud: #/$defs/ESQLTagcloudPanelConfig
        treemap: #/$defs/ESQLTreemapPanelConfig
        waffle: #/$defs/ESQLWafflePanelConfig
      propertyName: type
    oneOf[12]{"$ref"}:
      #/$defs/ESQLMetricPanelConfig
      #/$defs/ESQLGaugePanelConfig
      #/$defs/ESQLHeatmapPanelConfig
      #/$defs/ESQLPiePanelConfig
      #/$defs/ESQLLinePanelConfig
      #/$defs/ESQLBarPanelConfig
      #/$defs/ESQLAreaPanelConfig
      #/$defs/ESQLTagcloudPanelConfig
      #/$defs/ESQLDatatablePanelConfig
      #/$defs/ESQLMosaicPanelConfig
      #/$defs/ESQLTreemapPanelConfig
      #/$defs/ESQLWafflePanelConfig
  ESQLPiePanelConfig:
    additionalProperties: false
    description: Configuration for an ES|QL pie panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/PieChartAppearance
          - type: "null"
        default: null
        description: "Formatting options for the chart appearance, including donut size."
      breakdowns:
        description: "The breakdowns that determine the slices of the pie chart. First breakdown is primary, additional breakdowns are secondary."
        items:
          "$ref": #/$defs/ESQLDimensionTypes
        title: Breakdowns
        type: array
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      legend:
        anyOf[2]:
          - "$ref": #/$defs/PieLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metrics:
        description: Metrics that determine the size of slices.
        items:
          "$ref": #/$defs/ESQLMetricTypes
        minItems: 1
        title: Metrics
        type: array
      query:
        "$ref": #/$defs/ESQLQueryTypes
        description: The ES|QL query to execute.
      time_field:
        default: @timestamp
        description: The time field to use for the dashboard time picker. Defaults to '@timestamp'.
        title: Time Field
        type: string
      type:
        const: pie
        default: pie
        title: Type
        type: string
    required[3]: query,metrics,breakdowns
    title: ESQLPiePanelConfig
    type: object
  ESQLQueryMultiSelectControl:
    additionalProperties: false
    description: "Represents an ES|QL control with query-driven values for multiple selection.\n\nThis control dynamically fetches available values from an ES|QL query\nto filter ES|QL visualizations via variables."
    properties:
      default:
        anyOf[2]:
          - items:
              type: string
            type: array
          - type: "null"
        default: null
        description: Default selected values.
        title: Default
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the control. If not provided, a label may be inferred."
        title: Label
      multiple:
        const: true
        default: true
        description: Must be True for multi-select.
        title: Multiple
        type: boolean
      query:
        description: The ES|QL query that returns the available values for this control.
        minLength: 1
        title: Query
        type: string
      type:
        const: esql
        default: esql
        title: Type
        type: string
      variable_name:
        description: "The name of the ES|QL variable (e.g., 'status_code')."
        title: Variable Name
        type: string
      variable_type:
        "$ref": #/$defs/ESQLVariableType
        default: values
        description: "The type of variable ('time_literal', 'fields', 'values', 'multi_values', 'functions')."
      width:
        anyOf[2]:
          - enum[3]: large,medium,small
            type: string
          - type: "null"
        default: null
        description: "The width of the control in the dashboard layout. If not set, defaults to 'medium'."
        title: Width
    required[2]: variable_name,query
    title: ESQLQueryMultiSelectControl
    type: object
  ESQLQuerySingleSelectControl:
    additionalProperties: false
    description: "Represents an ES|QL control with query-driven values for single selection.\n\nThis control dynamically fetches available values from an ES|QL query\nto filter ES|QL visualizations via variables."
    properties:
      default:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Default selected value.
        title: Default
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the control. If not provided, a label may be inferred."
        title: Label
      multiple:
        anyOf[2]:
          - const: false
            type: boolean
          - type: "null"
        default: null
        description: Must be None or False for single-select.
        title: Multiple
      query:
        description: The ES|QL query that returns the available values for this control.
        minLength: 1
        title: Query
        type: string
      type:
        const: esql
        default: esql
        title: Type
        type: string
      variable_name:
        description: "The name of the ES|QL variable (e.g., 'status_code')."
        title: Variable Name
        type: string
      variable_type:
        "$ref": #/$defs/ESQLVariableType
        default: values
        description: "The type of variable ('time_literal', 'fields', 'values', 'multi_values', 'functions')."
      width:
        anyOf[2]:
          - enum[3]: large,medium,small
            type: string
          - type: "null"
        default: null
        description: "The width of the control in the dashboard layout. If not set, defaults to 'medium'."
        title: Width
    required[2]: variable_name,query
    title: ESQLQuerySingleSelectControl
    type: object
  ESQLQueryTypes:
    anyOf[2]:
      - type: string
      - items:
          anyOf[2]:
            - type: string
            - items:
              type: array
        type: array
    description: "Represents an ESQL (Elasticsearch Query Language) query configuration.\n\nESQL is a powerful query language for Elasticsearch that provides a flexible syntax for filtering data.\n\nThe query can be provided as either:\n- A string: The complete ESQL query\n- A list of strings: Query parts that will be concatenated with pipe characters (|)\n\nThe list format supports YAML anchors for query reuse. When anchors reference arrays,\nthey create nested lists which are automatically flattened before concatenation.\n\nExample with YAML anchors:\n    .base: &base_query\n      - FROM logs-*\n      - WHERE @timestamp > NOW() - 1h\n\n    query:\n      - *base_query\n      - STATS count = COUNT()\n\n    # Results in:\n    # FROM logs-*\n    # | WHERE @timestamp > NOW() - 1h\n    # | STATS count = COUNT()"
    title: ESQLQuery
  ESQLStaticMultiSelectControl:
    additionalProperties: false
    description: "Represents an ES|QL control with static values for multiple selection.\n\nThis control allows users to select multiple values from a predefined list\nto filter ES|QL visualizations via variables."
    properties:
      choices:
        description: The static list of available values for this control.
        items:
          type: string
        title: Choices
        type: array
      default:
        anyOf[2]:
          - items:
              type: string
            type: array
          - type: "null"
        default: null
        description: Default selected values.
        title: Default
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the control. If not provided, a label may be inferred."
        title: Label
      multiple:
        const: true
        default: true
        description: Must be True for this control type.
        title: Multiple
        type: boolean
      type:
        const: esql
        default: esql
        title: Type
        type: string
      variable_name:
        description: "The name of the ES|QL variable (e.g., 'status_code')."
        title: Variable Name
        type: string
      variable_type:
        "$ref": #/$defs/ESQLVariableType
        default: values
        description: "The type of variable ('time_literal', 'fields', 'values', 'multi_values', 'functions')."
      width:
        anyOf[2]:
          - enum[3]: large,medium,small
            type: string
          - type: "null"
        default: null
        description: "The width of the control in the dashboard layout. If not set, defaults to 'medium'."
        title: Width
    required[2]: variable_name,choices
    title: ESQLStaticMultiSelectControl
    type: object
  ESQLStaticSingleSelectControl:
    additionalProperties: false
    description: "Represents an ES|QL control with static values for single selection.\n\nThis control allows users to select a single value from a predefined list\nto filter ES|QL visualizations via variables."
    properties:
      choices:
        description: The static list of available values for this control.
        items:
          type: string
        title: Choices
        type: array
      default:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Default selected value.
        title: Default
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the control. If not provided, a label may be inferred."
        title: Label
      multiple:
        anyOf[2]:
          - const: false
            type: boolean
          - type: "null"
        default: null
        description: "If true, allow multiple selection. Must be None or False for this control type."
        title: Multiple
      type:
        const: esql
        default: esql
        title: Type
        type: string
      variable_name:
        description: "The name of the ES|QL variable (e.g., 'status_code')."
        title: Variable Name
        type: string
      variable_type:
        "$ref": #/$defs/ESQLVariableType
        default: values
        description: "The type of variable ('time_literal', 'fields', 'values', 'multi_values', 'functions')."
      width:
        anyOf[2]:
          - enum[3]: large,medium,small
            type: string
          - type: "null"
        default: null
        description: "The width of the control in the dashboard layout. If not set, defaults to 'medium'."
        title: Width
    required[2]: variable_name,choices
    title: ESQLStaticSingleSelectControl
    type: object
  ESQLTagcloudPanelConfig:
    additionalProperties: false
    description: Configuration for an ES|QL tagcloud panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/TagcloudAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart colors.
      dimension:
        "$ref": #/$defs/ESQLDimensionTypes
        description: The dimension for grouping (terms). This determines the tags shown in the cloud.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      metric:
        "$ref": #/$defs/ESQLMetricTypes
        description: The metric for sizing. This determines the size of each tag.
      query:
        "$ref": #/$defs/ESQLQueryTypes
        description: The ES|QL query to execute.
      time_field:
        default: @timestamp
        description: The time field to use for the dashboard time picker. Defaults to '@timestamp'.
        title: Time Field
        type: string
      type:
        const: tagcloud
        default: tagcloud
        title: Type
        type: string
    required[3]: query,dimension,metric
    title: ESQLTagcloudPanelConfig
    type: object
  ESQLTreemapBreakdownTypes:
    additionalProperties: false
    description: A dimension that is defined in the ESQL query.
    properties:
      data_type:
        anyOf[2]:
          - const: date
            type: string
          - type: "null"
        default: null
        description: The data type of the field. Set to 'date' for time/date fields to enable proper sorting and formatting.
        title: Data Type
      field:
        description: The field to use for the dimension.
        title: Field
        type: string
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Optional display label for the dimension.
        title: Label
    required[1]: field
    title: ESQLDimension
    type: object
  ESQLTreemapPanelConfig:
    additionalProperties: false
    description: Configuration for an ES|QL treemap panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/TreemapAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      breakdowns:
        description: Breakdowns that determine treemap grouping levels. Maximum 2 breakdowns supported.
        items:
          "$ref": #/$defs/ESQLTreemapBreakdownTypes
        maxItems: 2
        title: Breakdowns
        type: array
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      legend:
        anyOf[2]:
          - "$ref": #/$defs/TreemapLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metric:
        "$ref": #/$defs/ESQLMetricTypes
        description: Metric that determines the rectangle sizes. Treemap supports only one metric.
      query:
        "$ref": #/$defs/ESQLQueryTypes
        description: The ES|QL query to execute.
      time_field:
        default: @timestamp
        description: The time field to use for the dashboard time picker. Defaults to '@timestamp'.
        title: Time Field
        type: string
      type:
        const: treemap
        default: treemap
        description: "The type of chart, which is 'treemap' for this visualization."
        title: Type
        type: string
    required[3]: query,metric,breakdowns
    title: ESQLTreemapPanelConfig
    type: object
  ESQLVariableType:
    description: "Types of ES|QL variables.\n\nThese match the ESQLVariableType enum from Kibana's kbn-esql-types package."
    enum[5]: fields,functions,multi_values,time_literal,values
    title: ESQLVariableType
    type: string
  ESQLWafflePanelConfig:
    additionalProperties: false
    description: Configuration for an ES|QL waffle panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/WaffleAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/ESQLBreakdownTypes
          - type: "null"
        default: null
        description: Optional breakdown for grouping data. Waffle charts support only one breakdown.
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      legend:
        anyOf[2]:
          - "$ref": #/$defs/WaffleLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metric:
        "$ref": #/$defs/ESQLMetricTypes
        description: Metric that determines the size of squares. Waffle charts support only one metric.
      query:
        "$ref": #/$defs/ESQLQueryTypes
        description: The ES|QL query to execute.
      time_field:
        default: @timestamp
        description: The time field to use for the dashboard time picker. Defaults to '@timestamp'.
        title: Time Field
        type: string
      type:
        const: waffle
        default: waffle
        title: Type
        type: string
    required[2]: query,metric
    title: ESQLWafflePanelConfig
    type: object
  ESQLXYMetricTypes:
    additionalProperties: false
    description: "XY chart ESQL metric with appearance options.\n\nExtends ESQLMetric to include axis and color configuration\nfor use in XY charts."
    properties:
      axis:
        anyOf[2]:
          - enum[2]: left,right
            type: string
          - type: "null"
        default: null
        description: Which Y-axis to assign this metric to ('left' or 'right').
        title: Axis
      color:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "Custom color for this metric series (hex color code, e.g., '#2196F3')."
        title: Color
      field:
        description: The field in the data view that this metric is based on.
        title: Field
        type: string
      format:
        anyOf[2]:
          - "$ref": #/$defs/ESQLMetricFormatTypes
          - type: "null"
        default: null
        description: "The format of the metric (number, bytes, bits, percent, duration, or custom)."
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Optional display label for the metric.
        title: Label
    required[1]: field
    title: XYESQLMetric
    type: object
  ExistsFilter:
    additionalProperties: false
    description: "Represents an 'exists' filter configuration in the Config schema.\n\nThis filter checks for the existence or non-existence of a specific field."
    properties:
      alias:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "An optional alias for the filter, used for display purposes."
        title: Alias
      disabled:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "Indicates whether the filter is disabled. If `true`, the filter will not be applied."
        title: Disabled
      exists:
        description: "The field name to check for existence. If the field exists in a document, it will match that document."
        title: Exists
        type: string
    required[1]: exists
    title: ExistsFilter
    type: object
  FilterScalar:
    anyOf[4]{type}:
      string
      integer
      number
      boolean
  FilterTypes:
    oneOf[8]{"$ref"}:
      #/$defs/ExistsFilter
      #/$defs/PhraseFilter
      #/$defs/PhrasesFilter
      #/$defs/RangeFilter
      #/$defs/CustomFilter
      #/$defs/AndFilter
      #/$defs/OrFilter
      #/$defs/NegateFilter
  GaugeAppearance:
    additionalProperties: false
    description: "Appearance configuration for gauge visualizations.\n\nGroups all visual styling options for gauge charts including shape, tick positioning,\nand label configuration."
    properties:
      label_major:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Major label text to display on the gauge.
        title: Label Major
      label_minor:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Minor label text to display on the gauge.
        title: Label Minor
      shape:
        anyOf[2]:
          - enum[5]: arc,circle,horizontal_bullet,semi_circle,vertical_bullet
            type: string
          - type: "null"
        default: null
        description: The shape of the gauge visualization.
        title: Shape
      ticks_position:
        anyOf[2]:
          - enum[3]: auto,bands,hidden
            type: string
          - type: "null"
        default: null
        description: Position of tick marks on the gauge.
        title: Ticks Position
    title: GaugeAppearance
    type: object
  GaugeTitlesAndText:
    additionalProperties: false
    description: "Title and subtitle display options for gauges.\n\nThese fields map to Kibana gauge `labelMajor` (title) and `labelMinor` (subtitle).\n\n- ``None`` (omit): Kibana default (auto for title, hidden for subtitle)\n- ``False``: explicitly hidden\n- ``str``: custom text"
    properties:
      subtitle:
        anyOf[3]:
          - type: string
          - const: false
            type: boolean
          - type: "null"
        default: null
        description: "Gauge subtitle. Omit for no subtitle, ``False`` to hide, or a string for custom text."
        title: Subtitle
      title:
        anyOf[3]:
          - type: string
          - const: false
            type: boolean
          - type: "null"
        default: null
        description: "Gauge title. Omit for Kibana default, ``False`` to hide, or a string for custom text."
        title: Title
    title: GaugeTitlesAndText
    type: object
  HeatmapAppearance:
    additionalProperties: false
    description: Formatting options for the chart appearance.
    properties:
      legend:
        anyOf[2]:
          - "$ref": #/$defs/HeatmapLegendConfig
          - type: "null"
        default: null
        description: Configuration for the color legend.
      values:
        anyOf[2]:
          - "$ref": #/$defs/HeatmapValuesConfig
          - type: "null"
        default: null
        description: Configuration for numeric values shown in heatmap cells.
      x_axis:
        anyOf[2]:
          - "$ref": #/$defs/HeatmapAxisAppearance
          - type: "null"
        default: null
        description: Configuration for the X-axis labels and title.
      y_axis:
        anyOf[2]:
          - "$ref": #/$defs/HeatmapAxisAppearance
          - type: "null"
        default: null
        description: Configuration for the Y-axis labels and title.
    title: HeatmapAppearance
    type: object
  HeatmapAxisAppearance:
    additionalProperties: false
    description: Appearance configuration for a heatmap axis.
    properties:
      labels:
        anyOf[2]:
          - "$ref": #/$defs/HeatmapAxisLabelsConfig
          - type: "null"
        default: null
        description: Configuration for axis tick labels.
      title:
        anyOf[2]:
          - "$ref": #/$defs/HeatmapAxisTitleConfig
          - type: "null"
        default: null
        description: Configuration for axis title visibility.
    title: HeatmapAxisAppearance
    type: object
  HeatmapAxisLabelsConfig:
    additionalProperties: false
    description: Configuration for heatmap axis tick labels.
    properties:
      visible:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to show tick labels on the axis.
        title: Visible
    title: HeatmapAxisLabelsConfig
    type: object
  HeatmapAxisTitleConfig:
    additionalProperties: false
    description: Configuration for heatmap axis titles.
    properties:
      visible:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to show the axis title.
        title: Visible
    title: HeatmapAxisTitleConfig
    type: object
  HeatmapLegendConfig:
    additionalProperties: false
    description: "Legend configuration for heatmap visualizations.\n\nControls the visibility and position of the color legend.\nNote: Heatmaps only support 'show' and 'hide' visibility options (not 'auto')."
    properties:
      position:
        anyOf[2]:
          - enum[4]: bottom,left,right,top
            type: string
          - type: "null"
        default: null
        description: Position of the legend.
        title: Position
      visible:
        anyOf[2]:
          - "$ref": #/$defs/LegendVisibleEnum
          - type: "null"
        default: null
        description: Visibility of the legend. Kibana defaults vary by chart type.
      width:
        anyOf[2]:
          - "$ref": #/$defs/LegendWidthEnum
          - type: "null"
        default: null
        description: Width of the legend.
    title: HeatmapLegendConfig
    type: object
  HeatmapValuesConfig:
    additionalProperties: false
    description: Configuration for heatmap numeric values.
    properties:
      visible:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to show numeric values inside heatmap cells.
        title: Visible
    title: HeatmapValuesConfig
    type: object
  ImagePanel:
    additionalProperties: false
    description: "Represents an Image panel configuration.\n\nImage panels are used to display images.\n\nExamples:\n    Minimal image panel:\n    ```yaml\n    dashboards:\n      - name: \"Branded Dashboard\"\n        panels:\n          - title: \"Company Logo\"\n            size: { w: 16, h: 3 }\n            image:\n              from_url: \"https://example.com/path/to/your/logo.png\"\n    ```\n\n    Image panel with custom fit and background:\n    ```yaml\n    dashboards:\n      - name: \"Dashboard with Diagram\"\n        panels:\n          - title: \"System Architecture Diagram\"\n            size: { w: 48, h: 6 }\n            image:\n              from_url: \"https://example.com/path/to/architecture.svg\"\n              fit: \"contain\"\n              background_color: \"#f0f0f0\"\n    ```"
    properties:
      description:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: A brief description of the panel's content or purpose. Defaults to an empty string.
        title: Description
      drilldowns:
        anyOf[2]:
          - items:
              "$ref": #/$defs/DrilldownTypes
            type: array
          - type: "null"
        default: null
        description: Optional list of drilldowns to attach to this panel.
        title: Drilldowns
      hide_title:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, the panel title will be hidden. Defaults to `false` (title is shown)."
        title: Hide Title
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier for the panel. If not provided, one may be generated during compilation."
        title: Id
      image:
        "$ref": #/$defs/ImagePanelConfig
        description: Image panel configuration.
      position:
        "$ref": #/$defs/Position
        description: "Defines the panel's position on the dashboard grid. If not specified, position will be auto-calculated."
      size:
        "$ref": #/$defs/Size
        description: Defines the panel's size on the dashboard grid.
      title:
        default: ""
        description: The title displayed on the panel header. Can be an empty string.
        title: Title
        type: string
    required[1]: image
    title: ImagePanel
    type: object
  ImagePanelConfig:
    additionalProperties: false
    description: Configuration specific to Image panels.
    properties:
      background_color:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Background color for the image panel. Defaults to an empty string if not set.
        title: Background Color
      description:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "Alternative text for the image, used for accessibility. Defaults to an empty string if not set."
        title: Description
      fit:
        anyOf[2]:
          - enum[4]: contain,cover,fill,none
            type: string
          - type: "null"
        default: null
        description: "Controls how the image is sized within the panel. Defaults to \"contain\".\n\n- **contain**: Scales to fit within the panel while maintaining aspect ratio. Entire image visible.\n- **cover**: Scales to fill the panel while maintaining aspect ratio. May be cropped.\n- **fill**: Stretches or compresses to fill the panel, potentially altering aspect ratio.\n- **none**: Displays at original size. Cropped if larger, unchanged if smaller than panel."
        title: Fit
      from_url:
        description: The URL of the image to be displayed in the panel. This is a required field.
        title: From Url
        type: string
    required[1]: from_url
    title: ImagePanelConfig
    type: object
  KqlQuery:
    additionalProperties: false
    description: "Represents a KQL (Kibana Query Language) query configuration.\n\nKQL is the default query language in Kibana and provides a simplified syntax for filtering data."
    properties:
      kql:
        description: The Kibana Query Language (KQL) query string to apply.
        title: Kql
        type: string
    required[1]: kql
    title: KqlQuery
    type: object
  LegacyQueryTypes:
    oneOf[2]{"$ref"}:
      #/$defs/KqlQuery
      #/$defs/LuceneQuery
  LegendVisibleEnum:
    description: Represents the possible values for the visibility of the legend in a pie chart.
    enum[3]: auto,hide,show
    title: LegendVisibleEnum
    type: string
  LegendWidthEnum:
    description: Represents the possible values for the width/size of the legend.
    enum[4]: extra_large,large,medium,small
    title: LegendWidthEnum
    type: string
  LensAggregatedMetricTypes:
    anyOf[6]{"$ref"}:
      #/$defs/LensOtherAggregatedMetric
      #/$defs/LensLastValueAggregatedMetric
      #/$defs/LensCountAggregatedMetric
      #/$defs/LensSumAggregatedMetric
      #/$defs/LensPercentileRankAggregatedMetric
      #/$defs/LensPercentileAggregatedMetric
  LensAreaChart:
    additionalProperties: false
    description: "Represents an Area chart configuration within a Lens panel.\n\nExamples:\n    Simple area chart with time series:\n    ```yaml\n    lens:\n      type: area\n      data_view: \"logs-*\"\n      dimension:\n        type: date_histogram\n        field: \"@timestamp\"\n      metrics:\n        - aggregation: count\n    ```\n\n    Stacked area chart with percentage mode:\n    ```yaml\n    lens:\n      type: area\n      mode: percentage\n      data_view: \"metrics-*\"\n      dimension:\n        type: date_histogram\n        field: \"@timestamp\"\n      breakdown:\n        type: values\n        field: \"service.name\"\n      metrics:\n        - aggregation: count\n    ```"
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/AreaChartAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance. AreaChartAppearance includes all line chart options plus fill_opacity.
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/LensBreakdownTypes
          - type: "null"
        default: null
        description: "An optional breakdown to split the series by. If provided, it will be used to break down the data into multiple series."
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color palette.
      data_view:
        description: The data view to use for the chart.
        title: Data View
        type: string
      dimension:
        anyOf[2]:
          - "$ref": #/$defs/LensDimensionTypes
          - type: "null"
        default: null
        description: Defines the X-axis dimension for the chart. XY charts support 0 or 1 dimension.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      legend:
        anyOf[2]:
          - "$ref": #/$defs/XYLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metrics:
        description: Defines the metrics for the chart. At least one metric is required.
        items:
          "$ref": #/$defs/LensXYMetricTypes
        minItems: 1
        title: Metrics
        type: array
      mode:
        default: stacked
        description: The stacking mode for bar and area charts. Defaults to 'stacked'.
        enum[3]: percentage,stacked,unstacked
        title: Mode
        type: string
      type:
        const: area
        default: area
        description: The type of XY chart to display. Defaults to 'area'.
        title: Type
        type: string
    required[2]: data_view,metrics
    title: LensAreaChart
    type: object
  LensAreaPanelConfig:
    additionalProperties: false
    description: Configuration for a Lens area panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/AreaChartAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance. AreaChartAppearance includes all line chart options plus fill_opacity.
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/LensBreakdownTypes
          - type: "null"
        default: null
        description: "An optional breakdown to split the series by. If provided, it will be used to break down the data into multiple series."
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color palette.
      data_view:
        description: The data view to use for the chart.
        title: Data View
        type: string
      dimension:
        anyOf[2]:
          - "$ref": #/$defs/LensDimensionTypes
          - type: "null"
        default: null
        description: Defines the X-axis dimension for the chart. XY charts support 0 or 1 dimension.
      filters:
        anyOf[2]:
          - items:
              "$ref": #/$defs/FilterTypes
            type: array
          - type: "null"
        default: null
        description: A list of filters to apply to the panel.
        title: Filters
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      layers:
        anyOf[2]:
          - items:
              "$ref": #/$defs/MultiLayerChartTypes
            type: array
          - type: "null"
        default: null
        description: Optional additional layers for multi-layer XY charts (including reference lines).
        title: Layers
      legend:
        anyOf[2]:
          - "$ref": #/$defs/XYLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metrics:
        description: Defines the metrics for the chart. At least one metric is required.
        items:
          "$ref": #/$defs/LensXYMetricTypes
        minItems: 1
        title: Metrics
        type: array
      mode:
        default: stacked
        description: The stacking mode for bar and area charts. Defaults to 'stacked'.
        enum[3]: percentage,stacked,unstacked
        title: Mode
        type: string
      query:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: The query to be executed.
      type:
        const: area
        default: area
        description: The type of XY chart to display. Defaults to 'area'.
        title: Type
        type: string
    required[2]: data_view,metrics
    title: LensAreaPanelConfig
    type: object
  LensBarChart:
    additionalProperties: false
    description: "Represents a Bar chart configuration within a Lens panel.\n\nExamples:\n    Simple bar chart with time series:\n    ```yaml\n    lens:\n      type: bar\n      data_view: \"logs-*\"\n      dimension:\n        type: date_histogram\n        field: \"@timestamp\"\n      metrics:\n        - aggregation: count\n    ```\n\n    Stacked bar chart with breakdown:\n    ```yaml\n    lens:\n      type: bar\n      mode: stacked\n      data_view: \"logs-*\"\n      dimension:\n        type: date_histogram\n        field: \"@timestamp\"\n      breakdown:\n        type: values\n        field: \"service.name\"\n      metrics:\n        - aggregation: count\n    ```"
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/BarChartAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/LensBreakdownTypes
          - type: "null"
        default: null
        description: "An optional breakdown to split the series by. If provided, it will be used to break down the data into multiple series."
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color palette.
      data_view:
        description: The data view to use for the chart.
        title: Data View
        type: string
      dimension:
        anyOf[2]:
          - "$ref": #/$defs/LensDimensionTypes
          - type: "null"
        default: null
        description: Defines the X-axis dimension for the chart. XY charts support 0 or 1 dimension.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      legend:
        anyOf[2]:
          - "$ref": #/$defs/XYLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metrics:
        description: Defines the metrics for the chart. At least one metric is required.
        items:
          "$ref": #/$defs/LensXYMetricTypes
        minItems: 1
        title: Metrics
        type: array
      mode:
        default: stacked
        description: The stacking mode for bar and area charts. Defaults to 'stacked'.
        enum[3]: percentage,stacked,unstacked
        title: Mode
        type: string
      type:
        const: bar
        default: bar
        description: The type of XY chart to display. Defaults to 'bar'.
        title: Type
        type: string
    required[2]: data_view,metrics
    title: LensBarChart
    type: object
  LensBarPanelConfig:
    additionalProperties: false
    description: Configuration for a Lens bar panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/BarChartAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/LensBreakdownTypes
          - type: "null"
        default: null
        description: "An optional breakdown to split the series by. If provided, it will be used to break down the data into multiple series."
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color palette.
      data_view:
        description: The data view to use for the chart.
        title: Data View
        type: string
      dimension:
        anyOf[2]:
          - "$ref": #/$defs/LensDimensionTypes
          - type: "null"
        default: null
        description: Defines the X-axis dimension for the chart. XY charts support 0 or 1 dimension.
      filters:
        anyOf[2]:
          - items:
              "$ref": #/$defs/FilterTypes
            type: array
          - type: "null"
        default: null
        description: A list of filters to apply to the panel.
        title: Filters
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      layers:
        anyOf[2]:
          - items:
              "$ref": #/$defs/MultiLayerChartTypes
            type: array
          - type: "null"
        default: null
        description: Optional additional layers for multi-layer XY charts (including reference lines).
        title: Layers
      legend:
        anyOf[2]:
          - "$ref": #/$defs/XYLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metrics:
        description: Defines the metrics for the chart. At least one metric is required.
        items:
          "$ref": #/$defs/LensXYMetricTypes
        minItems: 1
        title: Metrics
        type: array
      mode:
        default: stacked
        description: The stacking mode for bar and area charts. Defaults to 'stacked'.
        enum[3]: percentage,stacked,unstacked
        title: Mode
        type: string
      query:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: The query to be executed.
      type:
        const: bar
        default: bar
        description: The type of XY chart to display. Defaults to 'bar'.
        title: Type
        type: string
    required[2]: data_view,metrics
    title: LensBarPanelConfig
    type: object
  LensBreakdownTypes:
    anyOf[5]{"$ref"}:
      #/$defs/LensTermsBreakdown
      #/$defs/LensMultiTermsBreakdown
      #/$defs/LensDateHistogramBreakdown
      #/$defs/LensFiltersBreakdown
      #/$defs/LensIntervalsBreakdown
  LensCountAggregatedMetric:
    additionalProperties: false
    description: "Represents a count metric configuration within a Lens chart.\n\nCount metrics are used to count the number of documents in a data view."
    properties:
      aggregation:
        default: count
        enum[2]: count,unique_count
        title: Aggregation
        type: string
      exclude_zeros:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to exclude zero values from the count. Kibana defaults to true if not specified.
        title: Exclude Zeros
      field:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The field to count. If not provided, the count will be of all documents in the data view."
        title: Field
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
    title: LensCountAggregatedMetric
    type: object
  LensCustomMetricFormat:
    additionalProperties: false
    description: "Custom format configuration for metrics using numeral.js patterns.\n\nUse this for complete control over numeric formatting with numeral.js syntax."
    properties:
      compact:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "Whether to use compact notation (e.g., 1.2K instead of 1200). Defaults to Kibana's behavior."
        title: Compact
      decimals:
        anyOf[2]:
          - minimum: 0
            type: integer
          - type: "null"
        default: null
        description: "The number of decimal places to display. If not specified, defaults to 0."
        title: Decimals
      pattern:
        description: "numeral.js format pattern (e.g., \"0,0.00\" for comma-separated numbers with 2 decimals)."
        title: Pattern
        type: string
      suffix:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "Optional suffix to display after the formatted number (e.g., \" requests\", \" users\")."
        title: Suffix
      type:
        const: custom
        default: custom
        description: Format type identifier. Must be 'custom' for custom formats.
        title: Type
        type: string
    required[1]: pattern
    title: LensCustomMetricFormat
    type: object
  LensDataMetricTypes:
    anyOf[2]{"$ref"}:
      #/$defs/LensFormulaMetric
      #/$defs/LensAggregatedMetricTypes
  LensDatatableBreakdownTypes:
    anyOf[5]{"$ref"}:
      #/$defs/DatatableLensTermsBreakdown
      #/$defs/DatatableLensMultiTermsBreakdown
      #/$defs/DatatableLensDateHistogramBreakdown
      #/$defs/DatatableLensFiltersBreakdown
      #/$defs/DatatableLensIntervalsBreakdown
  LensDatatableDimensionTypes:
    anyOf[5]{"$ref"}:
      #/$defs/DatatableLensTermsDimension
      #/$defs/DatatableLensMultiTermsDimension
      #/$defs/DatatableLensDateHistogramDimension
      #/$defs/DatatableLensFiltersDimension
      #/$defs/DatatableLensIntervalsDimension
  LensDatatableMetricTypes:
    anyOf[7]{"$ref"}:
      #/$defs/DatatableLensFormulaMetric
      #/$defs/DatatableLensCountAggregatedMetric
      #/$defs/DatatableLensSumAggregatedMetric
      #/$defs/DatatableLensOtherAggregatedMetric
      #/$defs/DatatableLensLastValueAggregatedMetric
      #/$defs/DatatableLensPercentileRankAggregatedMetric
      #/$defs/DatatableLensPercentileAggregatedMetric
  LensDatatablePanelConfig:
    additionalProperties: false
    description: Configuration for a Lens datatable panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/DatatableAppearance
          - type: "null"
        default: null
        description: Appearance settings for the datatable.
      breakdowns:
        description: List of breakdowns to use as row groupings.
        items:
          anyOf[2]{"$ref"}:
            #/$defs/LensDatatableBreakdownTypes
            #/$defs/LensBreakdownTypes
        title: Breakdowns
        type: array
      data_view:
        description: The data view that determines the data for the datatable chart.
        title: Data View
        type: string
      filters:
        anyOf[2]:
          - items:
              "$ref": #/$defs/FilterTypes
            type: array
          - type: "null"
        default: null
        description: A list of filters to apply to the panel.
        title: Filters
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      metrics:
        description: List of metrics to display as columns.
        items:
          anyOf[2]{"$ref"}:
            #/$defs/LensDatatableMetricTypes
            #/$defs/LensDataMetricTypes
        title: Metrics
        type: array
      metrics_split_by:
        anyOf[2]:
          - items:
              anyOf[2]{"$ref"}:
                #/$defs/LensDatatableDimensionTypes
                #/$defs/LensDimensionTypes
            type: array
          - type: "null"
        default: null
        description: Optional split-metrics-by dimensions (creates separate metric columns for each dimension value).
        title: Metrics Split By
      paging:
        anyOf[2]:
          - "$ref": #/$defs/DatatablePagingConfig
          - type: "null"
        default: null
        description: Optional pagination configuration.
      query:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: The query to be executed.
      sorting:
        anyOf[2]:
          - "$ref": #/$defs/DatatableSortingConfig
          - type: "null"
        default: null
        description: Optional sorting configuration.
      type:
        const: datatable
        default: datatable
        description: "The type of chart, which is 'datatable' for this visualization."
        title: Type
        type: string
    required[1]: data_view
    title: LensDatatablePanelConfig
    type: object
  LensDateHistogramBreakdown:
    additionalProperties: false
    description: Date histogram breakdown with optional collapse aggregation.
    properties:
      collapse:
        anyOf[2]:
          - "$ref": #/$defs/CollapseAggregationEnum
          - type: "null"
        default: null
        description: "Aggregate all breakdown values into a single bucket using this function (sum, avg, min, max)."
      field:
        description: The name of the field in the data view that this dimension is based on.
        title: Field
        type: string
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the dimension. If not provided, a label may be inferred from the field and type."
        title: Label
      minimum_interval:
        anyOf[2]:
          - "$ref": #/$defs/LensDateMathMinimumInterval
          - type: "null"
        default: null
        description: "The minimum interval using Elasticsearch date math format (e.g. `1m`, `1h`). Defaults to `auto`."
      partial_intervals:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, show partial intervals. Kibana defaults to `true` if not specified."
        title: Partial Intervals
      type:
        const: date_histogram
        default: date_histogram
        title: Type
        type: string
    required[1]: field
    title: LensDateHistogramBreakdown
    type: object
  LensDateHistogramDimension:
    additionalProperties: false
    description: "Represents a histogram dimension configuration within a Lens chart.\n\nDate histogram dimensions are used for aggregating data into buckets based on numeric ranges."
    properties:
      field:
        description: The name of the field in the data view that this dimension is based on.
        title: Field
        type: string
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the dimension. If not provided, a label may be inferred from the field and type."
        title: Label
      minimum_interval:
        anyOf[2]:
          - "$ref": #/$defs/LensDateMathMinimumInterval
          - type: "null"
        default: null
        description: "The minimum interval using Elasticsearch date math format (e.g. `1m`, `1h`). Defaults to `auto`."
      partial_intervals:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, show partial intervals. Kibana defaults to `true` if not specified."
        title: Partial Intervals
      type:
        const: date_histogram
        default: date_histogram
        title: Type
        type: string
    required[1]: field
    title: LensDateHistogramDimension
    type: object
  LensDateMathMinimumInterval:
    anyOf[2]:
      - const: auto
        type: string
      - pattern: "^[1-9][0-9]*(ms|s|m|h|d|w|M|q|y)$"
        type: string
  LensDimensionTypes:
    anyOf[5]{"$ref"}:
      #/$defs/LensTermsDimension
      #/$defs/LensMultiTermsDimension
      #/$defs/LensDateHistogramDimension
      #/$defs/LensFiltersDimension
      #/$defs/LensIntervalsDimension
  LensFiltersBreakdown:
    additionalProperties: false
    description: Filters breakdown with optional collapse aggregation.
    properties:
      collapse:
        anyOf[2]:
          - "$ref": #/$defs/CollapseAggregationEnum
          - type: "null"
        default: null
        description: "Aggregate all breakdown values into a single bucket using this function (sum, avg, min, max)."
      filters:
        description: The filters to use for the dimension.
        items:
          "$ref": #/$defs/LensFiltersDimensionFilter
        title: Filters
        type: array
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the dimension. If not provided, a label may be inferred from the field and type."
        title: Label
      type:
        const: filters
        default: filters
        title: Type
        type: string
    required[1]: filters
    title: LensFiltersBreakdown
    type: object
  LensFiltersDimension:
    additionalProperties: false
    description: "Represents a filters dimension configuration within a Lens chart.\n\nFilters dimensions are used for filtering data based on a field."
    properties:
      filters:
        description: The filters to use for the dimension.
        items:
          "$ref": #/$defs/LensFiltersDimensionFilter
        title: Filters
        type: array
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the dimension. If not provided, a label may be inferred from the field and type."
        title: Label
      type:
        const: filters
        default: filters
        title: Type
        type: string
    required[1]: filters
    title: LensFiltersDimension
    type: object
  LensFiltersDimensionFilter:
    additionalProperties: false
    description: A filter for a filters dimension.
    properties:
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the filter. If not provided, the query will be used as the label."
        title: Label
      query:
        "$ref": #/$defs/LegacyQueryTypes
        description: The query to use for the dimension.
    required[1]: query
    title: LensFiltersDimensionFilter
    type: object
  LensFormulaMetric:
    additionalProperties: false
    description: "Represents a formula metric configuration within a Lens chart.\n\nFormula metrics allow for custom calculations using Kibana's formula syntax.\nThe formula string is passed directly to Kibana, which handles parsing and\nAST generation internally.\n\nExample formulas:\n- Simple arithmetic: \"count() / 100\"\n- Field aggregations: \"(max(response.time) - min(response.time)) / average(response.time)\"\n- With filters: \"count(kql='status:error') / count() * 100\""
    properties:
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      formula:
        description: The formula string to be evaluated for this metric.
        title: Formula
        type: string
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
    required[1]: formula
    title: LensFormulaMetric
    type: object
  LensGaugePanelConfig:
    additionalProperties: false
    description: Configuration for a Lens gauge panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/GaugeAppearance
          - type: "null"
        default: null
        description: Visual appearance configuration for the gauge.
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorRangeMapping
          - type: "null"
        default: null
        description: "Range-based palette configuration for gauge thresholds. When set, enables palette color mode."
      data_view:
        description: The data view that determines the data for the gauge chart.
        title: Data View
        type: string
      filters:
        anyOf[2]:
          - items:
              "$ref": #/$defs/FilterTypes
            type: array
          - type: "null"
        default: null
        description: A list of filters to apply to the panel.
        title: Filters
      goal:
        anyOf[4]:
          - "$ref": #/$defs/LensMetricTypes
          - type: integer
          - type: number
          - type: "null"
        default: null
        description: An optional goal/target value to display as a reference. Can be a metric (field-based) or a static numeric value.
        title: Goal
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      maximum:
        anyOf[4]:
          - "$ref": #/$defs/LensMetricTypes
          - type: integer
          - type: number
          - type: "null"
        default: null
        description: An optional maximum value for the gauge range. Can be a metric (field-based) or a static numeric value.
        title: Maximum
      metric:
        "$ref": #/$defs/LensDataMetricTypes
        description: The primary metric to display in the gauge. This is the main value shown.
      minimum:
        anyOf[4]:
          - "$ref": #/$defs/LensMetricTypes
          - type: integer
          - type: number
          - type: "null"
        default: null
        description: An optional minimum value for the gauge range. Can be a metric (field-based) or a static numeric value.
        title: Minimum
      query:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: The query to be executed.
      titles_and_text:
        anyOf[2]:
          - "$ref": #/$defs/GaugeTitlesAndText
          - type: "null"
        default: null
        description: Title and subtitle options mapped to gauge `label_major` and `label_minor`.
      type:
        const: gauge
        default: gauge
        description: "The type of chart, which is 'gauge' for this visualization."
        title: Type
        type: string
    required[2]: data_view,metric
    title: LensGaugePanelConfig
    type: object
  LensHeatmapPanelConfig:
    additionalProperties: false
    description: Configuration for a Lens heatmap panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/HeatmapAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorRangeMapping
          - type: "null"
        default: null
        description: Optional range-based palette configuration for heatmap cell coloring.
      data_view:
        description: The data view that determines the data for the heatmap chart.
        title: Data View
        type: string
      filters:
        anyOf[2]:
          - items:
              "$ref": #/$defs/FilterTypes
            type: array
          - type: "null"
        default: null
        description: A list of filters to apply to the panel.
        title: Filters
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      metric:
        "$ref": #/$defs/LensDataMetricTypes
        description: The metric that determines cell color intensity.
      query:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: The query to be executed.
      type:
        const: heatmap
        default: heatmap
        description: "The type of chart, which is 'heatmap' for this visualization."
        title: Type
        type: string
      x_axis:
        "$ref": #/$defs/LensDimensionTypes
        description: The dimension to display on the X-axis (horizontal).
      y_axis:
        anyOf[2]:
          - "$ref": #/$defs/LensDimensionTypes
          - type: "null"
        default: null
        description: The dimension to display on the Y-axis (vertical). Optional for 1D heatmaps.
    required[3]: data_view,x_axis,metric
    title: LensHeatmapPanelConfig
    type: object
  LensIntervalsBreakdown:
    additionalProperties: false
    description: Intervals breakdown with optional collapse aggregation.
    properties:
      collapse:
        anyOf[2]:
          - "$ref": #/$defs/CollapseAggregationEnum
          - type: "null"
        default: null
        description: "Aggregate all breakdown values into a single bucket using this function (sum, avg, min, max)."
      field:
        description: The name of the field in the data view that this dimension is based on.
        title: Field
        type: string
      granularity:
        anyOf[2]:
          - maximum: 7
            minimum: 1
            type: integer
          - type: "null"
        default: null
        description: "Interval granularity divides the field into evenly spaced intervals based on the minimum and maximum values for the field.\nKibana defaults to 4 if not specified."
        title: Granularity
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      include_empty_intervals:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, include empty histogram buckets. Defaults to `true`."
        title: Include Empty Intervals
      intervals:
        anyOf[2]:
          - items:
              "$ref": #/$defs/LensIntervalsDimensionInterval
            type: array
          - type: "null"
        default: null
        description: "The intervals to use for the dimension. If not provided, intervals will be automatically picked."
        title: Intervals
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the dimension. If not provided, a label may be inferred from the field and type."
        title: Label
      type:
        const: intervals
        default: intervals
        title: Type
        type: string
    required[1]: field
    title: LensIntervalsBreakdown
    type: object
  LensIntervalsDimension:
    additionalProperties: false
    description: "Represents an intervals dimension configuration within a Lens chart.\n\nIntervals dimensions are used for aggregating data based on numeric ranges."
    properties:
      field:
        description: The name of the field in the data view that this dimension is based on.
        title: Field
        type: string
      granularity:
        anyOf[2]:
          - maximum: 7
            minimum: 1
            type: integer
          - type: "null"
        default: null
        description: "Interval granularity divides the field into evenly spaced intervals based on the minimum and maximum values for the field.\nKibana defaults to 4 if not specified."
        title: Granularity
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      include_empty_intervals:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, include empty histogram buckets. Defaults to `true`."
        title: Include Empty Intervals
      intervals:
        anyOf[2]:
          - items:
              "$ref": #/$defs/LensIntervalsDimensionInterval
            type: array
          - type: "null"
        default: null
        description: "The intervals to use for the dimension. If not provided, intervals will be automatically picked."
        title: Intervals
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the dimension. If not provided, a label may be inferred from the field and type."
        title: Label
      type:
        const: intervals
        default: intervals
        title: Type
        type: string
    required[1]: field
    title: LensIntervalsDimension
    type: object
  LensIntervalsDimensionInterval:
    additionalProperties: false
    description: A single interval for an intervals dimension.
    properties:
      from:
        anyOf[2]{type}:
          integer
          "null"
        default: null
        description: The start of the interval.
        title: From
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: The label for the interval.
        title: Label
      to:
        anyOf[2]{type}:
          integer
          "null"
        default: null
        description: The end of the interval.
        title: To
    title: LensIntervalsDimensionInterval
    type: object
  LensLastValueAggregatedMetric:
    additionalProperties: false
    description: "Represents a last value metric configuration within a Lens chart.\n\nLast value metrics are used to retrieve the most recent value of a field based on a specified sort order."
    properties:
      aggregation:
        const: last_value
        default: last_value
        title: Aggregation
        type: string
      date_field:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: The field used to determine the 'last' value.
        title: Date Field
      field:
        title: Field
        type: string
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
    required[1]: field
    title: LensLastValueAggregatedMetric
    type: object
  LensLineChart:
    additionalProperties: false
    description: "Represents a Line chart configuration within a Lens panel.\n\nExamples:\n    Simple line chart with time series:\n    ```yaml\n    lens:\n      type: line\n      data_view: \"metrics-*\"\n      dimension:\n        type: date_histogram\n        field: \"@timestamp\"\n      metrics:\n        - aggregation: average\n          field: response_time\n    ```\n\n    Line chart with dual Y-axes:\n    ```yaml\n    lens:\n      type: line\n      data_view: \"logs-*\"\n      dimension:\n        type: date_histogram\n        field: \"@timestamp\"\n      metrics:\n        - aggregation: count\n          id: \"request_count\"\n          axis: left\n        - aggregation: average\n          field: \"error.rate\"\n          id: \"error_rate\"\n          axis: right\n    ```"
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/LineChartAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/LensBreakdownTypes
          - type: "null"
        default: null
        description: "An optional breakdown to split the series by. If provided, it will be used to break down the data into multiple series."
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color palette.
      data_view:
        description: The data view to use for the chart.
        title: Data View
        type: string
      dimension:
        anyOf[2]:
          - "$ref": #/$defs/LensDimensionTypes
          - type: "null"
        default: null
        description: Defines the X-axis dimension for the chart. XY charts support 0 or 1 dimension.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      legend:
        anyOf[2]:
          - "$ref": #/$defs/XYLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metrics:
        description: Defines the metrics for the chart. At least one metric is required.
        items:
          "$ref": #/$defs/LensXYMetricTypes
        minItems: 1
        title: Metrics
        type: array
      type:
        const: line
        default: line
        description: The type of XY chart to display. Defaults to 'line'.
        title: Type
        type: string
    required[2]: data_view,metrics
    title: LensLineChart
    type: object
  LensLinePanelConfig:
    additionalProperties: false
    description: Configuration for a Lens line panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/LineChartAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/LensBreakdownTypes
          - type: "null"
        default: null
        description: "An optional breakdown to split the series by. If provided, it will be used to break down the data into multiple series."
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color palette.
      data_view:
        description: The data view to use for the chart.
        title: Data View
        type: string
      dimension:
        anyOf[2]:
          - "$ref": #/$defs/LensDimensionTypes
          - type: "null"
        default: null
        description: Defines the X-axis dimension for the chart. XY charts support 0 or 1 dimension.
      filters:
        anyOf[2]:
          - items:
              "$ref": #/$defs/FilterTypes
            type: array
          - type: "null"
        default: null
        description: A list of filters to apply to the panel.
        title: Filters
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      layers:
        anyOf[2]:
          - items:
              "$ref": #/$defs/MultiLayerChartTypes
            type: array
          - type: "null"
        default: null
        description: Optional additional layers for multi-layer XY charts (including reference lines).
        title: Layers
      legend:
        anyOf[2]:
          - "$ref": #/$defs/XYLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metrics:
        description: Defines the metrics for the chart. At least one metric is required.
        items:
          "$ref": #/$defs/LensXYMetricTypes
        minItems: 1
        title: Metrics
        type: array
      query:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: The query to be executed.
      type:
        const: line
        default: line
        description: The type of XY chart to display. Defaults to 'line'.
        title: Type
        type: string
    required[2]: data_view,metrics
    title: LensLinePanelConfig
    type: object
  LensMetricChartMetricTypes:
    anyOf[7]{"$ref"}:
      #/$defs/MetricLensFormulaMetric
      #/$defs/MetricLensCountAggregatedMetric
      #/$defs/MetricLensSumAggregatedMetric
      #/$defs/MetricLensOtherAggregatedMetric
      #/$defs/MetricLensLastValueAggregatedMetric
      #/$defs/MetricLensPercentileRankAggregatedMetric
      #/$defs/MetricLensPercentileAggregatedMetric
  LensMetricFormat:
    additionalProperties: false
    description: "Standard format configuration for displaying metric values.\n\nSupports common numeric formats with optional suffix and compact notation."
    properties:
      compact:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "Whether to use compact notation (e.g., 1.2K instead of 1200). Defaults to Kibana's behavior."
        title: Compact
      decimals:
        anyOf[2]:
          - minimum: 0
            type: integer
          - type: "null"
        default: null
        description: "The number of decimal places to display. If not specified, defaults to 2 for number/bytes/percent, 0 for bits/duration."
        title: Decimals
      suffix:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "Optional suffix to display after the formatted number (e.g., \" requests\", \" users\")."
        title: Suffix
      type:
        description: "The format type for the metric value.\n\nAvailable formats:\n- **number**: Plain numeric value with optional decimal places\n- **bytes**: Byte size formatting (B, KB, MB, GB, TB)\n- **bits**: Bit size formatting (b, Kb, Mb, Gb, Tb)\n- **percent**: Percentage formatting with % symbol\n- **duration**: Time duration formatting (ms, s, m, h, d)"
        enum[5]: bits,bytes,duration,number,percent
        title: Type
        type: string
    required[1]: type
    title: LensMetricFormat
    type: object
  LensMetricFormatTypes:
    anyOf[2]{"$ref"}:
      #/$defs/LensMetricFormat
      #/$defs/LensCustomMetricFormat
  LensMetricPanelConfig:
    additionalProperties: false
    description: Configuration for a Lens metric panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/MetricAppearance
          - type: "null"
        default: null
        description: Visual appearance configuration for the metric.
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/LensBreakdownTypes
          - type: "null"
        default: null
        description: An optional breakdown dimension to split metric values by category.
      data_view:
        description: The data view that determines the data for the metric chart.
        title: Data View
        type: string
      filters:
        anyOf[2]:
          - items:
              "$ref": #/$defs/FilterTypes
            type: array
          - type: "null"
        default: null
        description: A list of filters to apply to the panel.
        title: Filters
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      maximum:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricTypes
          - type: "null"
        default: null
        description: "An optional maximum metric to display, often used for comparison or thresholds."
      primary:
        "$ref": #/$defs/LensMetricChartMetricTypes
        description: The primary metric to display in the chart. This is the main value shown in the metric visualization.
      query:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: The query to be executed.
      secondary:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricChartMetricTypes
          - type: "null"
        default: null
        description: An optional secondary metric to display alongside the primary metric.
      titles_and_text:
        anyOf[2]:
          - "$ref": #/$defs/MetricTitlesAndText
          - type: "null"
        default: null
        description: Formatting options for the chart titles and text.
      type:
        const: metric
        default: metric
        description: "The type of chart, which is 'metric' for this visualization."
        title: Type
        type: string
    required[2]: data_view,primary
    title: LensMetricPanelConfig
    type: object
  LensMetricTypes:
    anyOf[3]{"$ref"}:
      #/$defs/LensFormulaMetric
      #/$defs/LensAggregatedMetricTypes
      #/$defs/LensStaticValue
  LensMosaicPanelConfig:
    additionalProperties: false
    description: Configuration for a Lens mosaic panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/MosaicAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/LensBreakdownTypes
          - type: "null"
        default: null
        description: Optional secondary breakdown for splitting the mosaic into sub-groups.
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color.
      data_view:
        description: The data view that determines the data for the mosaic chart.
        title: Data View
        type: string
      dimension:
        "$ref": #/$defs/LensDimensionTypes
        description: Primary dimension for grouping data. Mosaic charts support only one dimension.
      filters:
        anyOf[2]:
          - items:
              "$ref": #/$defs/FilterTypes
            type: array
          - type: "null"
        default: null
        description: A list of filters to apply to the panel.
        title: Filters
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      legend:
        anyOf[2]:
          - "$ref": #/$defs/MosaicLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metric:
        "$ref": #/$defs/LensDataMetricTypes
        description: Metric that determines the size of rectangles. Mosaic charts support only one metric.
      query:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: The query to be executed.
      type:
        const: mosaic
        default: mosaic
        title: Type
        type: string
    required[3]: data_view,metric,dimension
    title: LensMosaicPanelConfig
    type: object
  LensMultiTermsBreakdown:
    additionalProperties: false
    description: Multi-field top-values breakdown with optional collapse aggregation.
    properties:
      collapse:
        anyOf[2]:
          - "$ref": #/$defs/CollapseAggregationEnum
          - type: "null"
        default: null
        description: "Aggregate all breakdown values into a single bucket using this function (sum, avg, min, max)."
      exclude:
        anyOf[2]:
          - items:
              type: string
            type: array
          - type: "null"
        default: null
        description: A list of terms to exclude. Can be used with or without `exclude_is_regex`.
        title: Exclude
      exclude_is_regex:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, treat the values in the `exclude` list as regular expressions. Defaults to `false`."
        title: Exclude Is Regex
      fields:
        description: List of field names for multi-field aggregation. Requires at least 2 fields.
        items:
          type: string
        minItems: 2
        title: Fields
        type: array
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      include:
        anyOf[2]:
          - items:
              type: string
            type: array
          - type: "null"
        default: null
        description: A list of terms to include. Can be used with or without `include_is_regex`.
        title: Include
      include_is_regex:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, treat the values in the `include` list as regular expressions. Defaults to `false`."
        title: Include Is Regex
      include_missing_values:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, show a bucket for documents with a missing value for the field. Defaults to `false`."
        title: Include Missing Values
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the dimension. If not provided, a label may be inferred from the field and type."
        title: Label
      show_other_bucket:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, show a bucket for terms not included in the top size. Defaults to `true`."
        title: Show Other Bucket
      size:
        anyOf[2]{type}:
          integer
          "null"
        default: null
        description: The number of top terms to display.
        title: Size
      sort:
        anyOf[2]:
          - "$ref": #/$defs/Sort
          - type: "null"
        default: null
        description: The sort configuration for the terms.
      type:
        const: values
        default: values
        title: Type
        type: string
    required[1]: fields
    title: LensMultiTermsBreakdown
    type: object
  LensMultiTermsDimension:
    additionalProperties: false
    description: "Represents a multi-field top values dimension configuration within a Lens chart.\n\nMulti-terms dimensions are used for aggregating data based on unique combinations\nof values across multiple fields."
    properties:
      exclude:
        anyOf[2]:
          - items:
              type: string
            type: array
          - type: "null"
        default: null
        description: A list of terms to exclude. Can be used with or without `exclude_is_regex`.
        title: Exclude
      exclude_is_regex:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, treat the values in the `exclude` list as regular expressions. Defaults to `false`."
        title: Exclude Is Regex
      fields:
        description: List of field names for multi-field aggregation. Requires at least 2 fields.
        items:
          type: string
        minItems: 2
        title: Fields
        type: array
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      include:
        anyOf[2]:
          - items:
              type: string
            type: array
          - type: "null"
        default: null
        description: A list of terms to include. Can be used with or without `include_is_regex`.
        title: Include
      include_is_regex:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, treat the values in the `include` list as regular expressions. Defaults to `false`."
        title: Include Is Regex
      include_missing_values:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, show a bucket for documents with a missing value for the field. Defaults to `false`."
        title: Include Missing Values
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the dimension. If not provided, a label may be inferred from the field and type."
        title: Label
      show_other_bucket:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, show a bucket for terms not included in the top size. Defaults to `true`."
        title: Show Other Bucket
      size:
        anyOf[2]{type}:
          integer
          "null"
        default: null
        description: The number of top terms to display.
        title: Size
      sort:
        anyOf[2]:
          - "$ref": #/$defs/Sort
          - type: "null"
        default: null
        description: The sort configuration for the terms.
      type:
        const: values
        default: values
        title: Type
        type: string
    required[1]: fields
    title: LensMultiTermsDimension
    type: object
  LensOtherAggregatedMetric:
    additionalProperties: false
    description: Represents various aggregated metric configurations within a Lens chart.
    properties:
      aggregation:
        description: "The aggregation type for the metric (e.g., 'min', 'max', 'median', 'average', 'standard_deviation')."
        enum[5]: average,max,median,min,standard_deviation
        title: Aggregation
        type: string
      field:
        title: Field
        type: string
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
    required[2]: aggregation,field
    title: LensOtherAggregatedMetric
    type: object
  LensPanel:
    additionalProperties: false
    description: "Represents a Lens chart panel (single or multi-layer).\n\nThe lens field contains a discriminated union of chart panel configurations.\nThe chart type is determined by the 'type' field."
    properties:
      description:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: A brief description of the panel's content or purpose. Defaults to an empty string.
        title: Description
      drilldowns:
        anyOf[2]:
          - items:
              "$ref": #/$defs/DrilldownTypes
            type: array
          - type: "null"
        default: null
        description: Optional list of drilldowns to attach to this panel.
        title: Drilldowns
      hide_title:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, the panel title will be hidden. Defaults to `false` (title is shown)."
        title: Hide Title
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier for the panel. If not provided, one may be generated during compilation."
        title: Id
      lens:
        "$ref": #/$defs/LensPanelConfig
        description: Lens panel configuration.
      position:
        "$ref": #/$defs/Position
        description: "Defines the panel's position on the dashboard grid. If not specified, position will be auto-calculated."
      size:
        "$ref": #/$defs/Size
        description: Defines the panel's size on the dashboard grid.
      title:
        default: ""
        description: The title displayed on the panel header. Can be an empty string.
        title: Title
        type: string
    required[1]: lens
    title: LensPanel
    type: object
  LensPanelConfig:
    discriminator:
      mapping:
        area: #/$defs/LensAreaPanelConfig
        bar: #/$defs/LensBarPanelConfig
        datatable: #/$defs/LensDatatablePanelConfig
        gauge: #/$defs/LensGaugePanelConfig
        heatmap: #/$defs/LensHeatmapPanelConfig
        line: #/$defs/LensLinePanelConfig
        metric: #/$defs/LensMetricPanelConfig
        mosaic: #/$defs/LensMosaicPanelConfig
        pie: #/$defs/LensPiePanelConfig
        tagcloud: #/$defs/LensTagcloudPanelConfig
        treemap: #/$defs/LensTreemapPanelConfig
        waffle: #/$defs/LensWafflePanelConfig
      propertyName: type
    oneOf[12]{"$ref"}:
      #/$defs/LensMetricPanelConfig
      #/$defs/LensGaugePanelConfig
      #/$defs/LensHeatmapPanelConfig
      #/$defs/LensPiePanelConfig
      #/$defs/LensLinePanelConfig
      #/$defs/LensBarPanelConfig
      #/$defs/LensAreaPanelConfig
      #/$defs/LensTagcloudPanelConfig
      #/$defs/LensDatatablePanelConfig
      #/$defs/LensMosaicPanelConfig
      #/$defs/LensTreemapPanelConfig
      #/$defs/LensWafflePanelConfig
  LensPercentileAggregatedMetric:
    additionalProperties: false
    description: "Represents a percentile metric configuration within a Lens chart.\n\nPercentile metrics are used to determine the value at a specific percentile in a data set."
    properties:
      aggregation:
        const: percentile
        default: percentile
        title: Aggregation
        type: string
      field:
        title: Field
        type: string
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
      percentile:
        title: Percentile
        type: integer
    required[2]: field,percentile
    title: LensPercentileAggregatedMetric
    type: object
  LensPercentileRankAggregatedMetric:
    additionalProperties: false
    description: "Represents a percentile rank metric configuration within a Lens chart.\n\nPercentile rank metrics are used to determine the rank of a value in a data set."
    properties:
      aggregation:
        const: percentile_rank
        default: percentile_rank
        title: Aggregation
        type: string
      field:
        title: Field
        type: string
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
      rank:
        title: Rank
        type: integer
    required[2]: field,rank
    title: LensPercentileRankAggregatedMetric
    type: object
  LensPieChart:
    additionalProperties: false
    description: "Represents a Pie chart configuration within a Lens panel.\n\nPie charts are used to visualize the proportion of categories.\n\nExamples:\n    Simple pie chart showing traffic sources:\n    ```yaml\n    lens:\n      type: pie\n      data_view: \"logs-*\"\n      breakdowns:\n        - field: \"source.geo.country_name\"\n          type: values\n      metrics:\n        - aggregation: count\n    ```\n\n    Pie chart with custom colors:\n    ```yaml\n    lens:\n      type: pie\n      data_view: \"metrics-*\"\n      breakdowns:\n        - field: \"resource.attributes.os.type\"\n          type: values\n      metrics:\n        - aggregation: unique_count\n          field: resource.attributes.host.name\n      color:\n        palette: 'eui_amsterdam_color_blind'\n        assignments:\n          - values: ['linux']\n            color: '#00BF6F'\n          - values: ['windows']\n            color: '#006BB4'\n    ```"
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/PieChartAppearance
          - type: "null"
        default: null
        description: "Formatting options for the chart appearance, including donut size."
      breakdowns:
        description: "The breakdowns that determine the slices of the pie chart. First breakdown is primary, additional breakdowns are secondary."
        items:
          "$ref": #/$defs/LensBreakdownTypes
        title: Breakdowns
        type: array
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color.
      data_view:
        description: The data view that determines the data for the pie chart.
        title: Data View
        type: string
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      legend:
        anyOf[2]:
          - "$ref": #/$defs/PieLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metrics:
        description: Metrics that determine the size of slices.
        items:
          "$ref": #/$defs/LensDataMetricTypes
        minItems: 1
        title: Metrics
        type: array
      type:
        const: pie
        default: pie
        title: Type
        type: string
    required[3]: data_view,metrics,breakdowns
    title: LensPieChart
    type: object
  LensPiePanelConfig:
    additionalProperties: false
    description: Configuration for a Lens pie panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/PieChartAppearance
          - type: "null"
        default: null
        description: "Formatting options for the chart appearance, including donut size."
      breakdowns:
        description: "The breakdowns that determine the slices of the pie chart. First breakdown is primary, additional breakdowns are secondary."
        items:
          "$ref": #/$defs/LensBreakdownTypes
        title: Breakdowns
        type: array
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color.
      data_view:
        description: The data view that determines the data for the pie chart.
        title: Data View
        type: string
      filters:
        anyOf[2]:
          - items:
              "$ref": #/$defs/FilterTypes
            type: array
          - type: "null"
        default: null
        description: A list of filters to apply to the panel.
        title: Filters
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      legend:
        anyOf[2]:
          - "$ref": #/$defs/PieLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metrics:
        description: Metrics that determine the size of slices.
        items:
          "$ref": #/$defs/LensDataMetricTypes
        minItems: 1
        title: Metrics
        type: array
      query:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: The query to be executed.
      type:
        const: pie
        default: pie
        title: Type
        type: string
    required[3]: data_view,metrics,breakdowns
    title: LensPiePanelConfig
    type: object
  LensReferenceLineLayer:
    additionalProperties: false
    description: "Represents a reference line layer configuration for multi-layer panels.\n\nReference lines display static threshold values, SLA targets, or baseline values\non XY charts. They appear as horizontal or vertical lines with optional styling,\nlabels, and icons.\n\nUnlike data layers, reference lines don't query data - they display static values\nfor visual context and comparison."
    properties:
      data_view:
        description: The data view to use for the layer (required for Kibana compatibility).
        title: Data View
        type: string
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      reference_lines:
        description: List of reference lines to display in this layer.
        items:
          "$ref": #/$defs/XYReferenceLine
        title: Reference Lines
        type: array
      type:
        const: reference_line
        default: reference_line
        description: The type of layer. Always 'reference_line'.
        title: Type
        type: string
    required[1]: data_view
    title: LensReferenceLineLayer
    type: object
  LensStaticValue:
    additionalProperties: false
    description: "Represents a static numeric value metric in Lens charts.\n\nUsed to display a fixed numeric value rather than aggregating from data.\nCommonly used for gauge min/max/goal values or reference lines."
    properties:
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Optional label for the static value.
        title: Label
      value:
        anyOf[2]{type}:
          integer
          number
        description: The static numeric value to display.
        title: Value
    required[1]: value
    title: LensStaticValue
    type: object
  LensSumAggregatedMetric:
    additionalProperties: false
    description: "Represents a sum metric configuration within a Lens chart.\n\nSum metrics are used to sum the values of a field."
    properties:
      aggregation:
        const: sum
        default: sum
        title: Aggregation
        type: string
      exclude_zeros:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to exclude zero values from the sum. Kibana defaults to true if not specified.
        title: Exclude Zeros
      field:
        title: Field
        type: string
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
    required[1]: field
    title: LensSumAggregatedMetric
    type: object
  LensTagcloudChart:
    additionalProperties: false
    description: "Represents a Tagcloud chart configuration within a Lens panel.\n\nTagcloud charts are used to visualize term frequency as word/tag clouds.\n\nExamples:\n    Minimal tagcloud:\n    ```yaml\n    dashboards:\n    - name: \"Log Analysis\"\n      panels:\n        - title: \"Top Error Messages\"\n          size: { w: 48, h: 6 }\n          lens:\n            type: tagcloud\n            data_view: \"logs-*\"\n            dimension:\n              type: values\n              field: \"error.message\"\n            metric:\n              aggregation: count\n    ```\n\n    Advanced tagcloud with appearance customization:\n    ```yaml\n    dashboards:\n    - name: \"Advanced Tag Cloud\"\n      panels:\n        - title: \"Service Labels\"\n          size: { w: 48, h: 8 }\n          lens:\n            type: tagcloud\n            data_view: \"logs-*\"\n            dimension:\n              type: values\n              field: \"service.name\"\n            metric:\n              aggregation: count\n            appearance:\n              min_font_size: 12\n              max_font_size: 96\n              orientation: \"multiple\"\n              labels:\n                visible: false\n            color:\n              palette: \"kibana_palette\"\n    ```"
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/TagcloudAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart colors.
      data_view:
        description: The data view that determines the data for the tagcloud chart.
        title: Data View
        type: string
      dimension:
        "$ref": #/$defs/LensDimensionTypes
        description: The dimension for grouping (terms). This determines the tags shown in the cloud.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      metric:
        "$ref": #/$defs/LensDataMetricTypes
        description: The metric for sizing. This determines the size of each tag.
      type:
        const: tagcloud
        default: tagcloud
        title: Type
        type: string
    required[3]: data_view,dimension,metric
    title: LensTagcloudChart
    type: object
  LensTagcloudPanelConfig:
    additionalProperties: false
    description: Configuration for a Lens tagcloud panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/TagcloudAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart colors.
      data_view:
        description: The data view that determines the data for the tagcloud chart.
        title: Data View
        type: string
      dimension:
        "$ref": #/$defs/LensDimensionTypes
        description: The dimension for grouping (terms). This determines the tags shown in the cloud.
      filters:
        anyOf[2]:
          - items:
              "$ref": #/$defs/FilterTypes
            type: array
          - type: "null"
        default: null
        description: A list of filters to apply to the panel.
        title: Filters
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      metric:
        "$ref": #/$defs/LensDataMetricTypes
        description: The metric for sizing. This determines the size of each tag.
      query:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: The query to be executed.
      type:
        const: tagcloud
        default: tagcloud
        title: Type
        type: string
    required[3]: data_view,dimension,metric
    title: LensTagcloudPanelConfig
    type: object
  LensTermsBreakdown:
    additionalProperties: false
    description: Top-values breakdown with optional collapse aggregation.
    properties:
      collapse:
        anyOf[2]:
          - "$ref": #/$defs/CollapseAggregationEnum
          - type: "null"
        default: null
        description: "Aggregate all breakdown values into a single bucket using this function (sum, avg, min, max)."
      exclude:
        anyOf[2]:
          - items:
              type: string
            type: array
          - type: "null"
        default: null
        description: A list of terms to exclude. Can be used with or without `exclude_is_regex`.
        title: Exclude
      exclude_is_regex:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, treat the values in the `exclude` list as regular expressions. Defaults to `false`."
        title: Exclude Is Regex
      field:
        description: The name of the field in the data view that this dimension is based on.
        title: Field
        type: string
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      include:
        anyOf[2]:
          - items:
              type: string
            type: array
          - type: "null"
        default: null
        description: A list of terms to include. Can be used with or without `include_is_regex`.
        title: Include
      include_is_regex:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, treat the values in the `include` list as regular expressions. Defaults to `false`."
        title: Include Is Regex
      include_missing_values:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, show a bucket for documents with a missing value for the field. Defaults to `false`."
        title: Include Missing Values
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the dimension. If not provided, a label may be inferred from the field and type."
        title: Label
      show_other_bucket:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, show a bucket for terms not included in the top size. Defaults to `true`."
        title: Show Other Bucket
      size:
        anyOf[2]{type}:
          integer
          "null"
        default: null
        description: The number of top terms to display.
        title: Size
      sort:
        anyOf[2]:
          - "$ref": #/$defs/Sort
          - type: "null"
        default: null
        description: The sort configuration for the terms.
      type:
        const: values
        default: values
        title: Type
        type: string
    required[1]: field
    title: LensTermsBreakdown
    type: object
  LensTermsDimension:
    additionalProperties: false
    description: "Represents a single-field top values dimension configuration within a Lens chart.\n\nTerms dimensions are used for aggregating data based on unique values of a single field."
    properties:
      exclude:
        anyOf[2]:
          - items:
              type: string
            type: array
          - type: "null"
        default: null
        description: A list of terms to exclude. Can be used with or without `exclude_is_regex`.
        title: Exclude
      exclude_is_regex:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, treat the values in the `exclude` list as regular expressions. Defaults to `false`."
        title: Exclude Is Regex
      field:
        description: The name of the field in the data view that this dimension is based on.
        title: Field
        type: string
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      include:
        anyOf[2]:
          - items:
              type: string
            type: array
          - type: "null"
        default: null
        description: A list of terms to include. Can be used with or without `include_is_regex`.
        title: Include
      include_is_regex:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, treat the values in the `include` list as regular expressions. Defaults to `false`."
        title: Include Is Regex
      include_missing_values:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, show a bucket for documents with a missing value for the field. Defaults to `false`."
        title: Include Missing Values
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the dimension. If not provided, a label may be inferred from the field and type."
        title: Label
      show_other_bucket:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, show a bucket for terms not included in the top size. Defaults to `true`."
        title: Show Other Bucket
      size:
        anyOf[2]{type}:
          integer
          "null"
        default: null
        description: The number of top terms to display.
        title: Size
      sort:
        anyOf[2]:
          - "$ref": #/$defs/Sort
          - type: "null"
        default: null
        description: The sort configuration for the terms.
      type:
        const: values
        default: values
        title: Type
        type: string
    required[1]: field
    title: LensTermsDimension
    type: object
  LensTreemapPanelConfig:
    additionalProperties: false
    description: Configuration for a Lens treemap panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/TreemapAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      breakdowns:
        description: Breakdowns that determine treemap grouping levels. Maximum 2 breakdowns supported.
        items:
          "$ref": #/$defs/LensBreakdownTypes
        maxItems: 2
        title: Breakdowns
        type: array
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color.
      data_view:
        description: The data view that determines the data for the treemap chart.
        title: Data View
        type: string
      filters:
        anyOf[2]:
          - items:
              "$ref": #/$defs/FilterTypes
            type: array
          - type: "null"
        default: null
        description: A list of filters to apply to the panel.
        title: Filters
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      legend:
        anyOf[2]:
          - "$ref": #/$defs/TreemapLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metric:
        "$ref": #/$defs/LensDataMetricTypes
        description: Metric that determines the rectangle sizes. Treemap supports only one metric.
      query:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: The query to be executed.
      type:
        const: treemap
        default: treemap
        description: "The type of chart, which is 'treemap' for this visualization."
        title: Type
        type: string
    required[3]: data_view,metric,breakdowns
    title: LensTreemapPanelConfig
    type: object
  LensWafflePanelConfig:
    additionalProperties: false
    description: Configuration for a Lens waffle panel.
    properties:
      appearance:
        anyOf[2]:
          - "$ref": #/$defs/WaffleAppearance
          - type: "null"
        default: null
        description: Formatting options for the chart appearance.
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/LensBreakdownTypes
          - type: "null"
        default: null
        description: Optional breakdown for grouping data. Waffle charts support only one breakdown.
      color:
        anyOf[2]:
          - "$ref": #/$defs/ColorValueMapping
          - type: "null"
        default: null
        description: Formatting options for the chart color.
      data_view:
        description: The data view that determines the data for the waffle chart.
        title: Data View
        type: string
      filters:
        anyOf[2]:
          - items:
              "$ref": #/$defs/FilterTypes
            type: array
          - type: "null"
        default: null
        description: A list of filters to apply to the panel.
        title: Filters
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      legend:
        anyOf[2]:
          - "$ref": #/$defs/WaffleLegend
          - type: "null"
        default: null
        description: Formatting options for the chart legend.
      metric:
        "$ref": #/$defs/LensDataMetricTypes
        description: Metric that determines the size of squares. Waffle charts support only one metric.
      query:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: The query to be executed.
      type:
        const: waffle
        default: waffle
        title: Type
        type: string
    required[2]: data_view,metric
    title: LensWafflePanelConfig
    type: object
  LensXYMetricTypes:
    anyOf[7]{"$ref"}:
      #/$defs/XYLensFormulaMetric
      #/$defs/XYLensCountAggregatedMetric
      #/$defs/XYLensSumAggregatedMetric
      #/$defs/XYLensOtherAggregatedMetric
      #/$defs/XYLensLastValueAggregatedMetric
      #/$defs/XYLensPercentileRankAggregatedMetric
      #/$defs/XYLensPercentileAggregatedMetric
  LineChartAppearance:
    additionalProperties: false
    description: "Represents line chart appearance formatting options.\n\nExtends BaseXYChartAppearance to include line-specific options."
    properties:
      end_values:
        anyOf[2]:
          - enum[3]: nearest,none,zero
            type: string
          - type: "null"
        default: null
        description: How to handle the end of the time range in line/area charts.
        title: End Values
      hide_endzones:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to hide end zones in time series charts (areas where data is incomplete).
        title: Hide Endzones
      line_style:
        anyOf[2]:
          - enum[3]: linear,monotone-x,step-after
            type: string
          - type: "null"
        default: null
        description: "The line style for line/area charts. Only 3 types are supported by Kibana: linear (straight), monotone-x (smooth), step-after (stepped)."
        title: Line Style
      missing_values:
        anyOf[2]:
          - enum[6]: average,carry,linear,lookahead,nearest,none
            type: string
          - type: "null"
        default: null
        description: How to handle missing data points. Controls interpolation for gaps in your data.
        title: Missing Values
      show_as_dotted:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, visually distinguish interpolated data from real data points. Defaults to `false`."
        title: Show As Dotted
      show_current_time_marker:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to show a vertical line at the current time in time series charts.
        title: Show Current Time Marker
      values:
        anyOf[2]:
          - "$ref": #/$defs/XYValuesConfig
          - type: "null"
        default: null
        description: Formatting options for value labels on data points.
      x_axis:
        anyOf[2]:
          - "$ref": #/$defs/AxisConfig
          - type: "null"
        default: null
        description: Configuration for the X-axis.
      y_left_axis:
        anyOf[2]:
          - "$ref": #/$defs/AxisConfig
          - type: "null"
        default: null
        description: Configuration for the left Y-axis.
      y_right_axis:
        anyOf[2]:
          - "$ref": #/$defs/AxisConfig
          - type: "null"
        default: null
        description: Configuration for the right Y-axis.
    title: LineChartAppearance
    type: object
  LinkTypes:
    oneOf[2]{"$ref"}:
      #/$defs/DashboardLink
      #/$defs/UrlLink
  LinksPanel:
    additionalProperties: false
    description: "Represents a Links panel configuration.\n\nLinks panels are used to display a collection of links to other dashboards,\nsaved objects, or external URLs.\n\nExamples:\n    Linking to another Dashboard:\n    ```yaml\n    dashboards:\n      - name: \"Main Overview\"\n        panels:\n          - title: \"Navigate to User Details\"\n            size: { w: 24, h: 2 }\n            links:\n              items:\n                - label: \"View User Activity Dashboard\"\n                  dashboard: \"user-activity-dashboard-id\"\n    ```\n\n    Linking to an External URL:\n    ```yaml\n    dashboards:\n      - name: \"Main Overview\"\n        panels:\n          - title: \"External Resources\"\n            size: { w: 24, h: 2 }\n            links:\n              items:\n                - label: \"Project Documentation\"\n                  url: \"https://docs.example.com/project-alpha\"\n                  new_tab: true\n    ```\n\n    Complex configuration with multiple link types:\n    ```yaml\n    dashboards:\n      - name: \"Operations Hub\"\n        panels:\n          - title: \"Quick Access\"\n            size: { w: 48, h: 3 }\n            links:\n              layout: \"vertical\"\n              items:\n              - label: \"Service Health Dashboard\"\n                dashboard: \"service-health-monitor-v2\"\n              - label: \"Runbook Wiki\"\n                url: \"https://internal.wiki/ops/runbooks\"\n                new_tab: true\n    ```"
    properties:
      description:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: A brief description of the panel's content or purpose. Defaults to an empty string.
        title: Description
      drilldowns:
        anyOf[2]:
          - items:
              "$ref": #/$defs/DrilldownTypes
            type: array
          - type: "null"
        default: null
        description: Optional list of drilldowns to attach to this panel.
        title: Drilldowns
      hide_title:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, the panel title will be hidden. Defaults to `false` (title is shown)."
        title: Hide Title
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier for the panel. If not provided, one may be generated during compilation."
        title: Id
      links:
        "$ref": #/$defs/LinksPanelConfig
        description: Links panel configuration.
      position:
        "$ref": #/$defs/Position
        description: "Defines the panel's position on the dashboard grid. If not specified, position will be auto-calculated."
      size:
        "$ref": #/$defs/Size
        description: Defines the panel's size on the dashboard grid.
      title:
        default: ""
        description: The title displayed on the panel header. Can be an empty string.
        title: Title
        type: string
    required[1]: links
    title: LinksPanel
    type: object
  LinksPanelConfig:
    additionalProperties: false
    description: Configuration specific to Links panels.
    properties:
      items:
        description: A list of link objects to be displayed in the panel.
        items:
          "$ref": #/$defs/LinkTypes
        title: Items
        type: array
      layout:
        anyOf[2]:
          - enum[2]: horizontal,vertical
            type: string
          - type: "null"
        default: null
        description: "The layout of the links in the panel, either 'horizontal' or 'vertical'. Kibana defaults to 'horizontal' if not set."
        title: Layout
    title: LinksPanelConfig
    type: object
  LuceneQuery:
    additionalProperties: false
    description: "Represents a Lucene query configuration.\n\nLucene provides a more powerful and flexible, but less friendly, syntax for querying data compared to KQL."
    properties:
      lucene:
        description: The Lucene query string to apply.
        title: Lucene
        type: string
    required[1]: lucene
    title: LuceneQuery
    type: object
  MarkdownPanel:
    additionalProperties: false
    description: "Represents a Markdown panel configuration.\n\nMarkdown panels are used to display rich text content using Markdown syntax.\n\nExamples:\n    Minimal Markdown panel:\n    ```yaml\n    dashboards:\n      - name: \"Dashboard with Markdown\"\n        panels:\n          - title: \"Welcome Note\"\n            size: { w: 48, h: 3 }\n            markdown:\n              content: |\n                ## Welcome to the Dashboard!\n                This panel provides an overview of the key metrics and reports available.\n\n                - Item 1\n                - Item 2\n    ```\n\n    Markdown panel with custom font size:\n    ```yaml\n    dashboards:\n      - name: \"Informational Dashboard\"\n        panels:\n          - title: \"Important Instructions\"\n            size: { w: 32, h: 5 }\n            markdown:\n              content: |\n                # Setup Guide\n\n                Please follow the [official documentation](https://strawgate.github.io/kb-yaml-to-lens/) for setup instructions.\n\n                Key steps:\n                1. **Download** the installer.\n                2. **Configure** the `config.yaml` file.\n                3. **Run** the start script.\n              font_size: 14\n    ```"
    properties:
      description:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: A brief description of the panel's content or purpose. Defaults to an empty string.
        title: Description
      drilldowns:
        anyOf[2]:
          - items:
              "$ref": #/$defs/DrilldownTypes
            type: array
          - type: "null"
        default: null
        description: Optional list of drilldowns to attach to this panel.
        title: Drilldowns
      hide_title:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, the panel title will be hidden. Defaults to `false` (title is shown)."
        title: Hide Title
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier for the panel. If not provided, one may be generated during compilation."
        title: Id
      markdown:
        "$ref": #/$defs/MarkdownPanelConfig
        description: Markdown panel configuration.
      position:
        "$ref": #/$defs/Position
        description: "Defines the panel's position on the dashboard grid. If not specified, position will be auto-calculated."
      size:
        "$ref": #/$defs/Size
        description: Defines the panel's size on the dashboard grid.
      title:
        default: ""
        description: The title displayed on the panel header. Can be an empty string.
        title: Title
        type: string
    required[1]: markdown
    title: MarkdownPanel
    type: object
  MarkdownPanelConfig:
    additionalProperties: false
    description: Configuration specific to Markdown panels.
    properties:
      content:
        description: The Markdown content to be displayed in the panel.
        title: Content
        type: string
      font_size:
        anyOf[2]{type}:
          integer
          "null"
        default: null
        description: "The font size for the Markdown content, in pixels. Defaults to 12 if not set."
        title: Font Size
      links_in_new_tab:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If true, links in the Markdown content will open in a new tab. Defaults to false if not set."
        title: Links In New Tab
    required[1]: content
    title: MarkdownPanelConfig
    type: object
  MatchTechnique:
    description: Enumeration for match techniques used in options list controls.
    enum[3]: contains,exact,prefix
    title: MatchTechnique
    type: string
  MetricAppearance:
    additionalProperties: false
    description: "Grouped appearance configuration for metric chart visualizations.\n\nGroups all visual styling options for metric charts including icons, progress bars,\nlayout, and font configuration."
    properties:
      breakdown:
        anyOf[2]:
          - "$ref": #/$defs/MetricBreakdownAppearance
          - type: "null"
        default: null
        description: Breakdown layout options.
      primary:
        anyOf[2]:
          - "$ref": #/$defs/MetricPrimaryAppearance
          - type: "null"
        default: null
        description: Primary metric appearance options.
      secondary:
        anyOf[2]:
          - "$ref": #/$defs/MetricSecondaryAppearance
          - type: "null"
        default: null
        description: Secondary metric appearance options.
    title: MetricAppearance
    type: object
  MetricBackgroundChart:
    additionalProperties: false
    description: Background chart options for the primary metric value.
    properties:
      direction:
        anyOf[2]:
          - enum[2]: horizontal,vertical
            type: string
          - type: "null"
        default: null
        description: Bar direction. Only valid when `type` is `bar`.
        title: Direction
      type:
        default: line
        description: Background chart mode. `none` hides the background chart.
        enum[3]: bar,line,none
        title: Type
        type: string
    title: MetricBackgroundChart
    type: object
  MetricBreakdownAppearance:
    additionalProperties: false
    description: Breakdown layout options.
    properties:
      column_count:
        anyOf[2]:
          - minimum: 1
            type: integer
          - type: "null"
        default: null
        description: Maximum number of columns when displaying broken-down metric values.
        title: Column Count
    title: MetricBreakdownAppearance
    type: object
  MetricChartColor:
    additionalProperties: false
    description: "Color settings for metric chart metrics, including thresholds and application mode."
    properties:
      apply_to:
        anyOf[2]:
          - enum[2]: background,value
            type: string
          - type: "null"
        default: null
        description: "Controls where metric colors are applied: value text or background."
        title: Apply To
      range_max:
        anyOf[2]{type}:
          number
          "null"
        default: null
        description: Optional upper bound for the palette domain.
        title: Range Max
      range_min:
        anyOf[2]{type}:
          number
          "null"
        default: 0
        description: Optional lower bound for the palette domain.
        title: Range Min
      range_type:
        default: number
        description: How threshold values are interpreted by Kibana.
        enum[2]: number,percent
        title: Range Type
        type: string
      thresholds:
        anyOf[2]:
          - items:
              "$ref": #/$defs/ColorThreshold
            minItems: 1
            type: array
          - type: "null"
        default: null
        description: Ordered threshold bands used to build color palettes.
        title: Thresholds
    title: MetricChartColor
    type: object
  MetricLensCountAggregatedMetric:
    additionalProperties: false
    description: Metric chart count metric with color options.
    properties:
      aggregation:
        default: count
        enum[2]: count,unique_count
        title: Aggregation
        type: string
      color:
        anyOf[2]:
          - "$ref": #/$defs/MetricChartColor
          - type: "null"
        default: null
        description: Color range mapping and application mode for this metric.
      exclude_zeros:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to exclude zero values from the count. Kibana defaults to true if not specified.
        title: Exclude Zeros
      field:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The field to count. If not provided, the count will be of all documents in the data view."
        title: Field
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
    title: MetricLensCountAggregatedMetric
    type: object
  MetricLensFormulaMetric:
    additionalProperties: false
    description: Metric chart formula metric with color options.
    properties:
      color:
        anyOf[2]:
          - "$ref": #/$defs/MetricChartColor
          - type: "null"
        default: null
        description: Color range mapping and application mode for this metric.
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      formula:
        description: The formula string to be evaluated for this metric.
        title: Formula
        type: string
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
    required[1]: formula
    title: MetricLensFormulaMetric
    type: object
  MetricLensLastValueAggregatedMetric:
    additionalProperties: false
    description: Metric chart last value metric with color options.
    properties:
      aggregation:
        const: last_value
        default: last_value
        title: Aggregation
        type: string
      color:
        anyOf[2]:
          - "$ref": #/$defs/MetricChartColor
          - type: "null"
        default: null
        description: Color range mapping and application mode for this metric.
      date_field:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: The field used to determine the 'last' value.
        title: Date Field
      field:
        title: Field
        type: string
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
    required[1]: field
    title: MetricLensLastValueAggregatedMetric
    type: object
  MetricLensOtherAggregatedMetric:
    additionalProperties: false
    description: Metric chart aggregated metric with color options.
    properties:
      aggregation:
        description: "The aggregation type for the metric (e.g., 'min', 'max', 'median', 'average', 'standard_deviation')."
        enum[5]: average,max,median,min,standard_deviation
        title: Aggregation
        type: string
      color:
        anyOf[2]:
          - "$ref": #/$defs/MetricChartColor
          - type: "null"
        default: null
        description: Color range mapping and application mode for this metric.
      field:
        title: Field
        type: string
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
    required[2]: aggregation,field
    title: MetricLensOtherAggregatedMetric
    type: object
  MetricLensPercentileAggregatedMetric:
    additionalProperties: false
    description: Metric chart percentile metric with color options.
    properties:
      aggregation:
        const: percentile
        default: percentile
        title: Aggregation
        type: string
      color:
        anyOf[2]:
          - "$ref": #/$defs/MetricChartColor
          - type: "null"
        default: null
        description: Color range mapping and application mode for this metric.
      field:
        title: Field
        type: string
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
      percentile:
        title: Percentile
        type: integer
    required[2]: field,percentile
    title: MetricLensPercentileAggregatedMetric
    type: object
  MetricLensPercentileRankAggregatedMetric:
    additionalProperties: false
    description: Metric chart percentile rank metric with color options.
    properties:
      aggregation:
        const: percentile_rank
        default: percentile_rank
        title: Aggregation
        type: string
      color:
        anyOf[2]:
          - "$ref": #/$defs/MetricChartColor
          - type: "null"
        default: null
        description: Color range mapping and application mode for this metric.
      field:
        title: Field
        type: string
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
      rank:
        title: Rank
        type: integer
    required[2]: field,rank
    title: MetricLensPercentileRankAggregatedMetric
    type: object
  MetricLensSumAggregatedMetric:
    additionalProperties: false
    description: Metric chart sum metric with color options.
    properties:
      aggregation:
        const: sum
        default: sum
        title: Aggregation
        type: string
      color:
        anyOf[2]:
          - "$ref": #/$defs/MetricChartColor
          - type: "null"
        default: null
        description: Color range mapping and application mode for this metric.
      exclude_zeros:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to exclude zero values from the sum. Kibana defaults to true if not specified.
        title: Exclude Zeros
      field:
        title: Field
        type: string
      filter:
        anyOf[2]:
          - "$ref": #/$defs/LegacyQueryTypes
          - type: "null"
        default: null
        description: A KQL filter applied before determining the metric value.
      format:
        anyOf[2]:
          - "$ref": #/$defs/LensMetricFormatTypes
          - type: "null"
        default: null
        description: The format of the metric.
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the metric. If not provided, a label may be inferred from the type and field."
        title: Label
    required[1]: field
    title: MetricLensSumAggregatedMetric
    type: object
  MetricPrimaryAppearance:
    additionalProperties: false
    description: Primary metric appearance options.
    properties:
      alignment:
        anyOf[2]:
          - enum[3]: center,left,right
            type: string
          - type: "null"
        default: null
        description: Text alignment for the primary metric value.
        title: Alignment
      background_chart:
        anyOf[2]:
          - "$ref": #/$defs/MetricBackgroundChart
          - type: "null"
        default: null
        description: Background chart options for the primary metric value.
      font_size:
        anyOf[2]:
          - enum[3]: custom,default,fit
            type: string
          - type: "null"
        default: null
        description: Font size mode for the primary metric value.
        title: Font Size
      icon:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Icon identifier to display alongside the primary metric value.
        title: Icon
      icon_position:
        anyOf[2]:
          - enum[2]: left,right
            type: string
          - type: "null"
        default: null
        description: Horizontal icon alignment relative to the primary metric value.
        title: Icon Position
      position:
        anyOf[2]:
          - enum[2]: bottom,top
            type: string
          - type: "null"
        default: null
        description: Vertical position of the primary metric value within the panel.
        title: Position
    title: MetricPrimaryAppearance
    type: object
  MetricSecondaryAppearance:
    additionalProperties: false
    description: Secondary metric appearance options.
    properties:
      alignment:
        anyOf[2]:
          - enum[3]: center,left,right
            type: string
          - type: "null"
        default: null
        description: Text alignment for the secondary metric value.
        title: Alignment
      label:
        anyOf[2]:
          - "$ref": #/$defs/MetricSecondaryLabelAppearance
          - type: "null"
        default: null
        description: Custom secondary label configuration.
    title: MetricSecondaryAppearance
    type: object
  MetricSecondaryLabelAppearance:
    additionalProperties: false
    description: Secondary metric label appearance options.
    properties:
      position:
        anyOf[2]:
          - enum[2]: after,before
            type: string
          - type: "null"
        default: null
        description: Position of secondary label relative to the metric value.
        title: Position
      text:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "Custom label text for the secondary metric, overriding its default label."
        title: Text
    title: MetricSecondaryLabelAppearance
    type: object
  MetricTitlesAndText:
    additionalProperties: false
    description: Titles and text formatting options for metric charts.
    properties:
      alignment:
        anyOf[2]:
          - enum[3]: center,left,right
            type: string
          - type: "null"
        default: null
        description: Text alignment for the metric title and subtitle.
        title: Alignment
      subtitle:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Custom subtitle text displayed below the metric title.
        title: Subtitle
      weight:
        anyOf[2]:
          - enum[3]: bold,lighter,normal
            type: string
          - type: "null"
        default: null
        description: Font weight for the metric title.
        title: Weight
    title: MetricTitlesAndText
    type: object
  MosaicAppearance:
    additionalProperties: false
    description: Formatting options for value labels.
    properties:
      values:
        anyOf[2]:
          - "$ref": #/$defs/MosaicValuesConfig
          - type: "null"
        default: null
        description: Formatting options for numeric values.
    title: MosaicAppearance
    type: object
  MosaicLegend:
    additionalProperties: false
    description: Represents legend formatting options for mosaic charts.
    properties:
      nested:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to show legend in nested format for multi-level mosaic charts. Kibana defaults to False if not specified.
        title: Nested
      position:
        anyOf[2]:
          - enum[4]: bottom,left,right,top
            type: string
          - type: "null"
        default: null
        description: Position of the legend.
        title: Position
      show_single_series:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to show legend when there is only one series. Kibana defaults to false if not specified.
        title: Show Single Series
      truncate_labels:
        anyOf[2]:
          - maximum: 5
            minimum: 0
            type: integer
          - type: "null"
        default: null
        description: Number of lines to truncate the legend labels to. Kibana defaults to 1 if not specified. Set to 0 to disable truncation.
        title: Truncate Labels
      visible:
        anyOf[2]:
          - "$ref": #/$defs/LegendVisibleEnum
          - type: "null"
        default: null
        description: Visibility of the legend. Kibana defaults vary by chart type.
      width:
        anyOf[2]:
          - "$ref": #/$defs/LegendWidthEnum
          - type: "null"
        default: null
        description: Width of the legend.
    title: MosaicLegend
    type: object
  MosaicValuesConfig:
    additionalProperties: false
    description: Formatting options for value labels.
    properties:
      decimal_places:
        anyOf[2]:
          - maximum: 10
            minimum: 0
            type: integer
          - type: "null"
        default: null
        description: Controls the number of decimal places for values in the mosaic chart. Kibana defaults to 2 if not specified.
        title: Decimal Places
      format:
        anyOf[2]:
          - enum[3]: hide,percent,value
            type: string
          - type: "null"
        default: null
        description: Controls how values are displayed in the mosaic chart. Kibana defaults to 'percent' if not specified.
        title: Format
    title: MosaicValuesConfig
    type: object
  MultiLayerChartTypes:
    anyOf[6]{"$ref"}:
      #/$defs/LensPieChart
      #/$defs/LensLineChart
      #/$defs/LensBarChart
      #/$defs/LensAreaChart
      #/$defs/LensTagcloudChart
      #/$defs/LensReferenceLineLayer
  NegateFilter:
    additionalProperties: false
    description: "Represents a negated filter configuration in the Config schema.\n\nThis allows for excluding documents that match the nested filter.\n\nNote: Unlike other filter types, NegateFilter extends BaseCfgModel directly\nrather than BaseFilter, so it does not support 'alias' or 'disabled' fields.\nThis is intentional - negation is a logical modifier that wraps another filter,\nand aliasing/disabling should be applied to the wrapped filter itself."
    properties:
      not:
        "$ref": #/$defs/FilterTypes
        description: "The filter to negate. Can be a phrase, phrases, or range filter."
    required[1]: not
    title: NegateFilter
    type: object
  OptionsListControl:
    additionalProperties: false
    description: "Represents an Options List control.\n\nThis control allows users to select one or more values from a list\nto filter data."
    properties:
      data_view:
        description: The ID or title of the data view (index pattern) the control operates on.
        title: Data View
        type: string
      field:
        description: The name of the field within the data view that the control is associated with.
        title: Field
        type: string
      fill_width:
        default: false
        description: "If true, the control will automatically adjust its width to fill available space."
        title: Fill Width
        type: boolean
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the control. If not provided, a label may be inferred."
        title: Label
      match_technique:
        anyOf[2]:
          - "$ref": #/$defs/MatchTechnique
          - type: "null"
        default: null
        description: "The search technique used for filtering options (e.g., 'prefix', 'contains', 'exact')."
      multiple:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If true, allow multiple selection."
        title: Multiple
      preselected:
        description: A list of options that are preselected when the control is initialized.
        items:
          type: string
        title: Preselected
        type: array
      type:
        const: options
        default: options
        title: Type
        type: string
      wait_for_results:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If set to true, delay the display of the list of values until the results are fully loaded."
        title: Wait For Results
      width:
        anyOf[2]:
          - enum[3]: large,medium,small
            type: string
          - type: "null"
        default: null
        description: "The width of the control in the dashboard layout. If not set, defaults to 'medium'."
        title: Width
    required[2]: field,data_view
    title: OptionsListControl
    type: object
  OrFilter:
    additionalProperties: false
    description: "Represents an 'or' filter configuration in the Config schema.\n\nThis filter matches documents that satisfy at least one of the specified filters."
    properties:
      alias:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "An optional alias for the filter, used for display purposes."
        title: Alias
      disabled:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "Indicates whether the filter is disabled. If `true`, the filter will not be applied."
        title: Disabled
      or:
        description: A list of filters. At least one filter must match for a document to be included.
        items:
          "$ref": #/$defs/FilterTypes
        title: Or
        type: array
    required[1]: or
    title: OrFilter
    type: object
  PanelTypes:
    oneOf[7]{"$ref"}:
      #/$defs/MarkdownPanel
      #/$defs/SearchPanel
      #/$defs/LinksPanel
      #/$defs/ImagePanel
      #/$defs/LensPanel
      #/$defs/ESQLPanel
      #/$defs/VegaPanel
  PhraseFilter:
    additionalProperties: false
    description: "Represents a 'phrase' filter configuration in the Config schema.\n\nThis filter matches documents where a specific field contains an exact phrase."
    properties:
      alias:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "An optional alias for the filter, used for display purposes."
        title: Alias
      disabled:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "Indicates whether the filter is disabled. If `true`, the filter will not be applied."
        title: Disabled
      equals:
        "$ref": #/$defs/FilterScalar
        description: The exact phrase value that the field must match.
      field:
        description: The field name to apply the filter to.
        title: Field
        type: string
    required[2]: field,equals
    title: PhraseFilter
    type: object
  PhrasesFilter:
    additionalProperties: false
    description: "Represents a 'phrases' filter configuration in the Config schema.\n\nThis filter matches documents where a specific field contains one or more\nof the specified phrases."
    properties:
      alias:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "An optional alias for the filter, used for display purposes."
        title: Alias
      disabled:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "Indicates whether the filter is disabled. If `true`, the filter will not be applied."
        title: Disabled
      field:
        description: The field name to apply the filter to.
        title: Field
        type: string
      in:
        description: A list of phrases. Documents must match at least one of these phrases in the specified field.
        items:
          "$ref": #/$defs/FilterScalar
        title: In
        type: array
    required[2]: field,in
    title: PhrasesFilter
    type: object
  PieCategoriesConfig:
    additionalProperties: false
    description: Formatting options for category labels.
    properties:
      position:
        anyOf[2]:
          - "$ref": #/$defs/PieSliceLabelsEnum
          - type: "null"
        default: null
        description: Controls the visibility of category labels in the pie chart. Kibana defaults to 'auto' if not specified.
    title: PieCategoriesConfig
    type: object
  PieChartAppearance:
    additionalProperties: false
    description: Represents chart appearance formatting options for Pie charts.
    properties:
      categories:
        anyOf[2]:
          - "$ref": #/$defs/PieCategoriesConfig
          - type: "null"
        default: null
        description: Formatting options for category labels.
      donut:
        anyOf[2]:
          - enum[3]: large,medium,small
            type: string
          - type: "null"
        default: null
        description: Controls the size of the donut hole in the pie chart. Kibana defaults to 'medium' if not specified.
        title: Donut
      values:
        anyOf[2]:
          - "$ref": #/$defs/PieValuesConfig
          - type: "null"
        default: null
        description: Formatting options for numeric values.
    title: PieChartAppearance
    type: object
  PieLegend:
    additionalProperties: false
    description: Represents legend formatting options for pie charts.
    properties:
      nested:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to show legend in nested format for multi-level pie charts. Kibana defaults to False if not specified.
        title: Nested
      position:
        anyOf[2]:
          - enum[4]: bottom,left,right,top
            type: string
          - type: "null"
        default: null
        description: Position of the legend.
        title: Position
      show_single_series:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to show legend when there is only one series. Kibana defaults to false if not specified.
        title: Show Single Series
      truncate_labels:
        anyOf[2]:
          - maximum: 5
            minimum: 0
            type: integer
          - type: "null"
        default: null
        description: Number of lines to truncate the legend labels to. Kibana defaults to 1 if not specified. Set to 0 to disable truncation.
        title: Truncate Labels
      visible:
        anyOf[2]:
          - "$ref": #/$defs/LegendVisibleEnum
          - type: "null"
        default: null
        description: Visibility of the legend. Kibana defaults vary by chart type.
      width:
        anyOf[2]:
          - "$ref": #/$defs/LegendWidthEnum
          - type: "null"
        default: null
        description: Width of the legend.
    title: PieLegend
    type: object
  PieSliceLabelsEnum:
    description: Represents the possible values for slice labels in a pie chart.
    enum[3]: auto,hide,inside
    title: PieSliceLabelsEnum
    type: string
  PieSliceValuesEnum:
    description: Represents the possible values for slice values in a pie chart.
    enum[3]: hide,integer,percent
    title: PieSliceValuesEnum
    type: string
  PieValuesConfig:
    additionalProperties: false
    description: Formatting options for numeric values.
    properties:
      decimal_places:
        anyOf[2]:
          - maximum: 10
            minimum: 0
            type: integer
          - type: "null"
        default: null
        description: Controls the number of decimal places for values in the pie chart. Kibana defaults to 2 if not specified.
        title: Decimal Places
      format:
        anyOf[2]:
          - "$ref": #/$defs/PieSliceValuesEnum
          - type: "null"
        default: null
        description: Controls the display of values in the pie chart. Kibana defaults to percent if not specified.
    title: PieValuesConfig
    type: object
  Position:
    additionalProperties: false
    description: "Panel position configuration.\n\nDetermines the x/y coordinates of a panel on the dashboard grid.\nIf not specified, the panel will be auto-positioned."
    properties:
      x:
        anyOf[2]:
          - maximum: 48
            minimum: 0
            type: integer
          - type: "null"
        default: null
        description: "The horizontal starting position of the panel on the grid (0-based). If None, position will be auto-calculated."
        title: X
      y:
        anyOf[2]:
          - minimum: 0
            type: integer
          - type: "null"
        default: null
        description: "The vertical starting position of the panel on the grid (0-based). If None, position will be auto-calculated."
        title: Y
    title: Position
    type: object
  RangeFilter:
    additionalProperties: false
    description: "Represents a 'range' filter configuration in the Config schema.\n\nThis filter matches documents where a numeric or date field falls within a specified range."
    properties:
      alias:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "An optional alias for the filter, used for display purposes."
        title: Alias
      disabled:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "Indicates whether the filter is disabled. If `true`, the filter will not be applied."
        title: Disabled
      field:
        description: The field name to apply the filter to.
        title: Field
        type: string
      gt:
        anyOf[2]:
          - "$ref": #/$defs/FilterScalar
          - type: "null"
        default: null
        description: Greater than value for the range filter.
      gte:
        anyOf[2]:
          - "$ref": #/$defs/FilterScalar
          - type: "null"
        default: null
        description: Greater than or equal to value for the range filter.
      lt:
        anyOf[2]:
          - "$ref": #/$defs/FilterScalar
          - type: "null"
        default: null
        description: Less than value for the range filter.
      lte:
        anyOf[2]:
          - "$ref": #/$defs/FilterScalar
          - type: "null"
        default: null
        description: Less than or equal to value for the range filter.
    required[1]: field
    title: RangeFilter
    type: object
  RangeSliderControl:
    additionalProperties: false
    description: "Represents a Range Slider control.\n\nThis control allows users to select a range of numeric or date values\nto filter data."
    properties:
      data_view:
        description: The ID or title of the data view (index pattern) the control operates on.
        title: Data View
        type: string
      field:
        description: The name of the field within the data view that the control is associated with.
        title: Field
        type: string
      fill_width:
        default: false
        description: "If true, the control will automatically adjust its width to fill available space."
        title: Fill Width
        type: boolean
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the control. If not provided, a label may be inferred."
        title: Label
      step:
        anyOf[3]{type}:
          integer
          number
          "null"
        default: null
        description: "The step value for the range, defining the granularity of selections."
        title: Step
      type:
        const: range
        default: range
        title: Type
        type: string
      width:
        anyOf[2]:
          - enum[3]: large,medium,small
            type: string
          - type: "null"
        default: null
        description: "The width of the control in the dashboard layout. If not set, defaults to 'medium'."
        title: Width
    required[2]: field,data_view
    title: RangeSliderControl
    type: object
  ReferenceLineIcon:
    enum[15]: alert,asterisk,bell,bolt,bug,circle,editor_comment,empty,flag,heart,map_marker,pin_filled,star_empty,tag,triangle
    type: string
  SampleData:
    additionalProperties: false
    description: Sample data configuration for dashboards.
    properties:
      create_index_template:
        default: false
        description: Whether to create an index template for sample data.
        title: Create Index Template
        type: boolean
      documents:
        anyOf[2]:
          - items:
              additionalProperties: true
              type: object
            type: array
          - type: "null"
        default: null
        description: Inline sample documents (when source='inline').
        title: Documents
      file_path:
        anyOf[2]:
          - format: path
            type: string
          - type: "null"
        default: null
        description: Path to NDJSON file with sample data (when source='file').
        title: File Path
      index_pattern:
        description: "Target index pattern for sample data (e.g., 'logs-*', 'metrics-*')."
        title: Index Pattern
        type: string
      index_template:
        anyOf[2]:
          - additionalProperties: true
            type: object
          - type: "null"
        default: null
        description: "Index template configuration (mappings, settings)."
        title: Index Template
      source:
        description: Whether sample data is inline in YAML or in an external file.
        enum[2]: file,inline
        title: Source
        type: string
      timestamp_transform:
        anyOf[2]:
          - "$ref": #/$defs/TimestampTransform
          - type: "null"
        description: Timestamp transformation configuration. Enabled by default to shift max timestamp to 'now'.
    required[2]: source,index_pattern
    title: SampleData
    type: object
  SearchPanel:
    additionalProperties: false
    description: "Represents a Search panel configuration.\n\nSearch panels are used to display the results of a saved Kibana search.\n\nExamples:\n    Minimal search panel:\n    ```yaml\n    dashboards:\n      - name: \"Log Monitoring Dashboard\"\n        panels:\n          - title: \"All System Logs\"\n            size: { w: 48, h: 10 }\n            search:\n              saved_search_id: \"a1b2c3d4-e5f6-7890-1234-567890abcdef\"\n    ```\n\n    Search panel with hidden title:\n    ```yaml\n    dashboards:\n      - name: \"Security Incidents Overview\"\n        panels:\n          - hide_title: true\n            description: \"Critical security alerts from the last 24 hours\"\n            size: { w: 48, h: 8 }\n            search:\n              saved_search_id: \"critical-security-alerts-saved-search\"\n    ```"
    properties:
      description:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: A brief description of the panel's content or purpose. Defaults to an empty string.
        title: Description
      drilldowns:
        anyOf[2]:
          - items:
              "$ref": #/$defs/DrilldownTypes
            type: array
          - type: "null"
        default: null
        description: Optional list of drilldowns to attach to this panel.
        title: Drilldowns
      hide_title:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, the panel title will be hidden. Defaults to `false` (title is shown)."
        title: Hide Title
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier for the panel. If not provided, one may be generated during compilation."
        title: Id
      position:
        "$ref": #/$defs/Position
        description: "Defines the panel's position on the dashboard grid. If not specified, position will be auto-calculated."
      search:
        "$ref": #/$defs/SearchPanelConfig
        description: Search panel configuration.
      size:
        "$ref": #/$defs/Size
        description: Defines the panel's size on the dashboard grid.
      title:
        default: ""
        description: The title displayed on the panel header. Can be an empty string.
        title: Title
        type: string
    required[1]: search
    title: SearchPanel
    type: object
  SearchPanelConfig:
    additionalProperties: false
    description: Configuration specific to Search panels.
    properties:
      saved_search_id:
        description: The ID of the saved Kibana search object to display in the panel.
        title: Saved Search Id
        type: string
    required[1]: saved_search_id
    title: SearchPanelConfig
    type: object
  SectionConfig:
    additionalProperties: false
    description: Configuration for a collapsible section's content and behavior.
    properties:
      collapsed:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether the section is collapsed by default in Kibana.
        title: Collapsed
      panels:
        description: "Panels contained within this collapsible section.\n\nInner panels use a **relative** coordinate space — their (x, y) positions\nstart at (0, 0) within the section body, independent of the section's\nabsolute position in the outer dashboard grid.\n\nNested CollapsiblePanels are not supported and will be rejected by the\nDashboard-level discriminator."
        items:
          "$ref": #/$defs/PanelTypes
        title: Panels
        type: array
    title: SectionConfig
    type: object
  Size:
    additionalProperties: false
    description: "Panel size configuration.\n\nDetermines the width and height of a panel on the dashboard grid.\nWidth accepts semantic values ('whole', 'half', etc.) or integers."
    properties:
      h:
        default: 8
        description: The height of the panel in grid units. Defaults to 8.
        exclusiveMinimum: 0
        title: H
        type: integer
      w:
        anyOf[2]:
          - type: integer
          - enum[6]: eighth,half,quarter,sixth,third,whole
            type: string
        default: 12
        description: "The width of the panel in grid units.\n\nDefaults to 12 (quarter width). Accepts semantic values ('whole', 'half', 'third', 'quarter', 'sixth', 'eighth') or integers (1-48)."
        title: W
    title: Size
    type: object
  Sort:
    additionalProperties: false
    description: Represents a sort configuration in the Config schema.
    properties:
      by:
        description: The field name to sort the data by.
        title: By
        type: string
      direction:
        description: The sort direction. Must be either 'asc' for ascending or 'desc' for descending.
        enum[2]: asc,desc
        title: Direction
        type: string
    required[2]: by,direction
    title: Sort
    type: object
  TagcloudAppearance:
    additionalProperties: false
    description: Appearance settings for tagcloud.
    properties:
      labels:
        anyOf[2]:
          - "$ref": #/$defs/TagcloudLabelsConfig
          - type: "null"
        default: null
        description: Label visibility configuration.
      max_font_size:
        anyOf[2]:
          - maximum: 200
            minimum: 1
            type: integer
          - type: "null"
        default: 72
        description: Maximum font size for tags. Defaults to 72.
        title: Max Font Size
      min_font_size:
        anyOf[2]:
          - maximum: 100
            minimum: 1
            type: integer
          - type: "null"
        default: 12
        description: Minimum font size for tags. Defaults to 12.
        title: Min Font Size
      orientation:
        anyOf[2]:
          - "$ref": #/$defs/TagcloudOrientationEnum
          - type: "null"
        default: single
        description: Text orientation configuration. Defaults to 'single'.
    title: TagcloudAppearance
    type: object
  TagcloudLabelsConfig:
    additionalProperties: false
    description: Label visibility settings for tagcloud.
    properties:
      visible:
        anyOf[2]{type}:
          boolean
          "null"
        default: true
        description: Toggle for label visibility. Defaults to True.
        title: Visible
    title: TagcloudLabelsConfig
    type: object
  TagcloudOrientationEnum:
    description: "Text orientation options for tagcloud visualizations.\n\nControls how tags are rotated in the word cloud display."
    enum[3]: multiple,right angled,single
    title: TagcloudOrientationEnum
    type: string
  TimeRange:
    additionalProperties: false
    description: Configure a default time range for the dashboard.
    properties:
      from:
        description: "The start of the time range (e.g., 'now-30d/d', 'now-1h')."
        title: From
        type: string
      to:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: The end of the time range.
        title: To
    required[1]: from
    title: TimeRange
    type: object
  TimeSliderControl:
    additionalProperties: false
    description: "Represents a Time Slider control.\n\nThis control allows users to select a time range to filter data\nby adjusting start and end offsets within the global time range."
    properties:
      end_offset:
        anyOf[2]:
          - maximum: 1
            minimum: 0
            type: number
          - type: "null"
        default: null
        description: "The end offset for the time range as a %, defining the end of the selection."
        title: End Offset
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the control. If not provided, a label may be inferred."
        title: Label
      start_offset:
        anyOf[2]:
          - maximum: 1
            minimum: 0
            type: number
          - type: "null"
        default: null
        description: "The start offset for the time range as a %, defining the beginning of the selection."
        title: Start Offset
      type:
        const: time
        default: time
        title: Type
        type: string
      width:
        anyOf[2]:
          - enum[3]: large,medium,small
            type: string
          - type: "null"
        default: null
        description: "The width of the control in the dashboard layout. If not set, defaults to 'medium'."
        title: Width
    title: TimeSliderControl
    type: object
  TimestampTransform:
    additionalProperties: false
    description: Configuration for timestamp transformation in sample data.
    properties:
      enabled:
        default: true
        description: "Whether to apply timestamp transformation.\n\nWhen enabled, shifts all timestamps so the maximum becomes 'now'."
        title: Enabled
        type: boolean
      field:
        default: @timestamp
        description: Name of the timestamp field to transform.
        title: Field
        type: string
    title: TimestampTransform
    type: object
  TreemapAppearance:
    additionalProperties: false
    description: Formatting options for treemap appearance.
    properties:
      categories:
        anyOf[2]:
          - "$ref": #/$defs/TreemapCategoriesConfig
          - type: "null"
        default: null
        description: Formatting options for category labels.
      values:
        anyOf[2]:
          - "$ref": #/$defs/TreemapValuesConfig
          - type: "null"
        default: null
        description: Formatting options for numeric values.
    title: TreemapAppearance
    type: object
  TreemapCategoriesConfig:
    additionalProperties: false
    description: Formatting options for category labels.
    properties:
      position:
        anyOf[2]:
          - "$ref": #/$defs/TreemapSliceLabelsEnum
          - type: "null"
        default: null
        description: Controls the visibility of category labels. Defaults to show when not specified.
    title: TreemapCategoriesConfig
    type: object
  TreemapLegend:
    additionalProperties: false
    description: Represents legend formatting options for treemap charts.
    properties:
      nested:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to show legend in nested format for multi-level pie charts. Kibana defaults to False if not specified.
        title: Nested
      position:
        anyOf[2]:
          - enum[4]: bottom,left,right,top
            type: string
          - type: "null"
        default: null
        description: Position of the legend.
        title: Position
      show_single_series:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to show legend when there is only one series. Kibana defaults to false if not specified.
        title: Show Single Series
      truncate_labels:
        anyOf[2]:
          - maximum: 5
            minimum: 0
            type: integer
          - type: "null"
        default: null
        description: Number of lines to truncate the legend labels to. Kibana defaults to 1 if not specified. Set to 0 to disable truncation.
        title: Truncate Labels
      visible:
        anyOf[2]:
          - "$ref": #/$defs/LegendVisibleEnum
          - type: "null"
        default: null
        description: Visibility of the legend. Kibana defaults vary by chart type.
      width:
        anyOf[2]:
          - "$ref": #/$defs/LegendWidthEnum
          - type: "null"
        default: null
        description: Width of the legend.
    title: TreemapLegend
    type: object
  TreemapSliceLabelsEnum:
    description: Represents the possible values for treemap slice labels.
    enum[2]: hide,show
    title: TreemapSliceLabelsEnum
    type: string
  TreemapValuesConfig:
    additionalProperties: false
    description: Formatting options for numeric values.
    properties:
      decimal_places:
        anyOf[2]:
          - maximum: 10
            minimum: 0
            type: integer
          - type: "null"
        default: null
        description: Controls the number of decimal places for values.
        title: Decimal Places
      format:
        anyOf[2]:
          - "$ref": #/$defs/PieSliceValuesEnum
          - type: "null"
        default: null
        description: Controls the display of values in treemap rectangles. Defaults to percent.
    title: TreemapValuesConfig
    type: object
  UrlDrilldown:
    additionalProperties: false
    description: URL drilldown configuration.
    properties:
      encode_url:
        default: true
        description: Whether to URL-encode the template variables. Defaults to True.
        title: Encode Url
        type: boolean
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "Optional unique identifier for the drilldown. If not provided, one will be generated."
        title: Id
      name:
        description: Display name for the drilldown.
        title: Name
        type: string
      new_tab:
        default: false
        description: Whether to open the URL in a new tab. Defaults to False.
        title: New Tab
        type: boolean
      triggers:
        description: "List of triggers that activate this drilldown. Defaults to ['click']."
        items:
          "$ref": #/$defs/DrilldownTrigger
        title: Triggers
        type: array
      url:
        description: Target URL template. Can include Kibana template variables.
        title: Url
        type: string
    required[2]: name,url
    title: UrlDrilldown
    type: object
  UrlLink:
    additionalProperties: false
    description: Represents a link to an external URL within a Links panel.
    properties:
      encode:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, the URL will be URL-encoded. Kibana defaults to `True` if not set."
        title: Encode
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: An optional unique identifier for the link. Not normally required.
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: The text that will be displayed for the link. Kibana defaults to showing the URL if not set.
        title: Label
      new_tab:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, the link will open in a new browser tab. Kibana defaults to `false` if not set."
        title: New Tab
      url:
        description: The Web URL that the link points to.
        title: Url
        type: string
    required[1]: url
    title: UrlLink
    type: object
  VegaPanel:
    additionalProperties: false
    description: "Represents a Vega panel configuration.\n\nVega panels are used to create custom visualizations using the Vega grammar.\n\nExamples:\n    Minimal Vega panel:\n    ```yaml\n    dashboards:\n      - name: \"Dashboard with Vega\"\n        panels:\n          - title: \"Hello Vega\"\n            size: { w: 24, h: 15 }\n            vega:\n              spec:\n                $schema: https://vega.github.io/schema/vega/v3.json\n                width: 100\n                height: 30\n                marks:\n                  - type: text\n                    encode:\n                      update:\n                        text:\n                          value: \"Hello Vega!\"\n    ```\n\n    Vega panel with Elasticsearch data:\n    ```yaml\n    dashboards:\n      - name: \"Vega Data Dashboard\"\n        panels:\n          - title: \"Custom Chart\"\n            size: { w: 48, h: 20 }\n            vega:\n              spec:\n                $schema: https://vega.github.io/schema/vega-lite/v5.json\n                data:\n                  url:\n                    index: logs-*\n                    body:\n                      size: 0\n                      aggs:\n                        time_buckets:\n                          date_histogram:\n                            field: \"@timestamp\"\n                            fixed_interval: 1h\n                mark: line\n                encoding:\n                  x:\n                    field: key\n                    type: temporal\n                  y:\n                    field: doc_count\n                    type: quantitative\n    ```"
    properties:
      description:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: A brief description of the panel's content or purpose. Defaults to an empty string.
        title: Description
      drilldowns:
        anyOf[2]:
          - items:
              "$ref": #/$defs/DrilldownTypes
            type: array
          - type: "null"
        default: null
        description: Optional list of drilldowns to attach to this panel.
        title: Drilldowns
      hide_title:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: "If `true`, the panel title will be hidden. Defaults to `false` (title is shown)."
        title: Hide Title
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier for the panel. If not provided, one may be generated during compilation."
        title: Id
      position:
        "$ref": #/$defs/Position
        description: "Defines the panel's position on the dashboard grid. If not specified, position will be auto-calculated."
      size:
        "$ref": #/$defs/Size
        description: Defines the panel's size on the dashboard grid.
      title:
        default: ""
        description: The title displayed on the panel header. Can be an empty string.
        title: Title
        type: string
      vega:
        "$ref": #/$defs/VegaPanelConfig
        description: Vega panel configuration.
    required[1]: vega
    title: VegaPanel
    type: object
  VegaPanelConfig:
    additionalProperties: false
    description: Configuration specific to Vega panels.
    properties:
      spec:
        additionalProperties: true
        description: The Vega specification as a structured YAML/JSON object.
        title: Spec
        type: object
    required[1]: spec
    title: VegaPanelConfig
    type: object
  WaffleAppearance:
    additionalProperties: false
    description: Formatting options for value labels.
    properties:
      values:
        anyOf[2]:
          - "$ref": #/$defs/WaffleValuesConfig
          - type: "null"
        default: null
        description: Formatting options for numeric values.
    title: WaffleAppearance
    type: object
  WaffleLegend:
    additionalProperties: false
    description: Represents legend formatting options for waffle charts.
    properties:
      nested:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to show legend in nested format for multi-level waffle charts. Kibana defaults to False if not specified.
        title: Nested
      position:
        anyOf[2]:
          - enum[4]: bottom,left,right,top
            type: string
          - type: "null"
        default: null
        description: Position of the legend.
        title: Position
      show_single_series:
        anyOf[2]{type}:
          boolean
          "null"
        default: null
        description: Whether to show legend when there is only one series. Kibana defaults to false if not specified.
        title: Show Single Series
      truncate_labels:
        anyOf[2]:
          - maximum: 5
            minimum: 0
            type: integer
          - type: "null"
        default: null
        description: Number of lines to truncate the legend labels to. Kibana defaults to 1 if not specified. Set to 0 to disable truncation.
        title: Truncate Labels
      visible:
        anyOf[2]:
          - "$ref": #/$defs/LegendVisibleEnum
          - type: "null"
        default: null
        description: Visibility of the legend. Kibana defaults vary by chart type.
      width:
        anyOf[2]:
          - "$ref": #/$defs/LegendWidthEnum
          - type: "null"
        default: null
        description: Width of the legend.
    title: WaffleLegend
    type: object
  WaffleValuesConfig:
    additionalProperties: false
    description: Formatting options for value labels.
    properties:
      decimal_places:
        anyOf[2]:
          - maximum: 10
            minimum: 0
            type: integer
          - type: "null"
        default: null
        description: Controls the number of decimal places for values in the waffle chart. Kibana defaults to 2 if not specified.
        title: Decimal Places
      format:
        anyOf[2]:
          - enum[3]: hide,percent,value
            type: string
          - type: "null"
        default: null
        description: Controls how values are displayed in the waffle chart. Kibana defaults to 'percent' if not specified.
        title: Format
    title: WaffleValuesConfig
    type: object
  XYLegend:
    additionalProperties: false
    description: Represents legend formatting options for XY charts.
