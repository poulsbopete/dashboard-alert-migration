      format:
        anyOf[2]:
          - "$ref": #/$defs/ESQLMetricFormatTypes
          - type: "null"
        default: null
        description: "The format of the metric (number, bytes, bits, percent, duration, or custom)."
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
