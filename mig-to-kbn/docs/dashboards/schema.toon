        anyOf[2]:
          - const: date
            type: string
          - type: "null"
        default: null
        description: The data type of the field. Set to 'date' for time/date fields to enable proper sorting and formatting.
        title: Data Type
      field:
        description: The field to use for the dimension.
        title: Field
        type: string
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
