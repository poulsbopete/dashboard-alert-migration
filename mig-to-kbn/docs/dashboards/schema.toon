    type: object
  ESQLFieldControl:
    additionalProperties: false
    description: ES|QL control for single field selection from static list.
    properties:
      choices:
        description: The static list of available fields for this control.
        items:
          type: string
        title: Choices
        type: array
      default:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Default selected field.
        title: Default
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the control. If not provided, a label may be inferred."
        title: Label
      type:
        const: esql
        default: esql
        title: Type
        type: string
      variable_name:
        description: The name of the ES|QL variable.
        title: Variable Name
        type: string
      variable_type:
        const: fields
        default: fields
        description: The type of variable ('fields').
        title: Variable Type
        type: string
      width:
        anyOf[2]:
          - enum[3]: large,medium,small
            type: string
          - type: "null"
        default: null
        description: "The width of the control in the dashboard layout. If not set, defaults to 'medium'."
        title: Width
    required[2]: variable_name,choices
    title: ESQLFieldControl
    type: object
  ESQLFunctionControl:
    additionalProperties: false
    description: ES|QL control for single function selection from static list.
    properties:
      choices:
        description: The static list of available functions for this control.
        items:
          type: string
        title: Choices
        type: array
      default:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: Default selected function.
        title: Default
      id:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "A unique identifier. If not provided, one will be generated automatically."
        title: Id
      label:
        anyOf[2]{type}:
          string
          "null"
        default: null
        description: "The display label for the control. If not provided, a label may be inferred."
        title: Label
      type:
