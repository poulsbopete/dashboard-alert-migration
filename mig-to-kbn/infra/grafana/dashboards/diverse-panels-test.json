{
  "id": null,
  "uid": "diverse-panel-test",
  "title": "Diverse Panel Types Test",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "tags": [
    "test",
    "diverse-panels"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "prometheus"
        }
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(up, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Annotations & Alerts",
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "type": "dashboard",
        "builtIn": 1
      }
    ]
  },
  "links": [
    {
      "title": "GitHub",
      "type": "link",
      "url": "https://github.com/test",
      "targetBlank": true
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "heatmap",
      "title": "Request Latency Heatmap",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_bucket[5m])) by (le)",
          "refId": "A",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ],
      "options": {
        "calculate": true,
        "calculation": {
          "xBuckets": {
            "mode": "size",
            "value": "1min"
          }
        },
        "color": {
          "mode": "scheme",
          "scheme": "Oranges",
          "steps": 128
        },
        "yAxis": {
          "unit": "s"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "log",
              "log": 2
            }
          }
        }
      }
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "Traffic Distribution",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{instance=~\"$instance\"}[5m])) by (handler)",
          "refId": "A",
          "legendFormat": "{{handler}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "pieType": "pie",
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Top Endpoints",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "topk(10, sum(rate(http_requests_total[5m])) by (handler))",
          "refId": "A",
          "legendFormat": "{{handler}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "barWidth": 0.8,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "System Metrics",
      "collapsed": true,
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 1
      },
      "panels": [
        {
          "id": 5,
          "type": "timeseries",
          "title": "CPU Usage",
          "gridPos": {
            "x": 0,
            "y": 17,
            "w": 12,
            "h": 8
          },
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "targets": [
            {
              "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
              "refId": "A",
              "legendFormat": "CPU %"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 70
                  },
                  {
                    "color": "red",
                    "value": 90
                  }
                ]
              },
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 20,
                "gradientMode": "scheme",
                "axisLabel": "CPU %",
                "axisSoftMin": 0,
                "axisSoftMax": 100
              }
            }
          }
        },
        {
          "id": 6,
          "type": "gauge",
          "title": "Memory Usage",
          "gridPos": {
            "x": 12,
            "y": 17,
            "w": 6,
            "h": 8
          },
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "targets": [
            {
              "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "orange",
                    "value": 70
                  },
                  {
                    "color": "red",
                    "value": 90
                  }
                ]
              }
            }
          }
        },
        {
          "id": 7,
          "type": "stat",
          "title": "Uptime",
          "gridPos": {
            "x": 18,
            "y": 17,
            "w": 6,
            "h": 4
          },
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "targets": [
            {
              "expr": "time() - node_boot_time_seconds",
              "refId": "A"
            }
          ],
          "options": {
            "reduceOptions": {
              "calcs": [
                "lastNotNull"
              ]
            },
            "colorMode": "background",
            "graphMode": "none",
            "textMode": "value_and_name"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "red",
                    "value": null
                  },
                  {
                    "color": "green",
                    "value": 86400
                  }
                ]
              }
            }
          }
        },
        {
          "id": 8,
          "type": "bargauge",
          "title": "Disk Usage per Mount",
          "gridPos": {
            "x": 18,
            "y": 21,
            "w": 6,
            "h": 4
          },
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "targets": [
            {
              "expr": "100 - ((node_filesystem_avail_bytes{mountpoint!~\".*pods.*\"} / node_filesystem_size_bytes) * 100)",
              "refId": "A",
              "legendFormat": "{{mountpoint}}"
            }
          ],
          "options": {
            "reduceOptions": {
              "calcs": [
                "lastNotNull"
              ]
            },
            "orientation": "horizontal",
            "displayMode": "gradient"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 70
                  },
                  {
                    "color": "red",
                    "value": 90
                  }
                ]
              }
            }
          }
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Active Alerts",
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "alertname"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          }
        ]
      }
    },
    {
      "id": 10,
      "type": "text",
      "title": "Notes",
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 12,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "## Dashboard Notes\n\nThis is a test dashboard covering all panel types.\n- Heatmap\n- Piechart\n- Barchart\n- Timeseries\n- Gauge\n- Stat\n- Bargauge\n- Table\n- Text"
      }
    },
    {
      "id": 11,
      "type": "logs",
      "title": "Application Logs",
      "gridPos": {
        "x": 12,
        "y": 31,
        "w": 12,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{job=\"app\"} |= \"error\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}