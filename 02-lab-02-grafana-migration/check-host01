#!/bin/bash
set -euo pipefail
cd /root/workshop
count="$(find build/elastic-dashboards -maxdepth 1 -type f -name '*.json' 2>/dev/null | wc -l | tr -d ' ')"
if [ "${count:-0}" -lt 12 ]; then
  fail-message "Expected at least 12 dashboard drafts in build/elastic-dashboards (found: ${count:-0})."
fi
if [ ! -f build/promql-notes.md ]; then
  fail-message "Create build/promql-notes.md with your PromQL → Elastic planning notes."
fi
