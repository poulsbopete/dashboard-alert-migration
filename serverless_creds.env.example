# Elastic Cloud Serverless — workshop credentials template
#
# Usage (from repo root):
#   cp serverless_creds.env.example serverless_creds.env
#   # Edit serverless_creds.env with real values (never commit that file)
#   set -a && source serverless_creds.env && set +a
#
# Then run migrate / publish scripts, e.g.:
#   bash scripts/migrate_grafana_dashboards_to_serverless.sh
#   bash scripts/migrate_datadog_dashboards_to_serverless.sh
#
# Where to get values:
#   • Elastic Cloud UI → Observability Serverless project → Endpoints
#   • Kibana → Stack Management → API keys (dashboards + rules scope)
#   • Instruqt VM: grep -E '^export (KIBANA_URL|ES_URL|ES_API_KEY|WORKSHOP_OTLP)' ~/.bashrc
#   • Managed OTLP: Kibana → Add data → OpenTelemetry (HTTPS ingest host)

# --- Required: migrate + publish dashboards to Kibana ---

export ES_URL="https://your-project-id.es.us-east-1.aws.elastic.cloud:443"
export ELASTICSEARCH_ENDPOINT="${ES_URL}"

export KIBANA_URL="https://your-project-id.kb.us-east-1.aws.elastic.cloud:443"
export KIBANA_ENDPOINT="${KIBANA_URL}"

export ES_API_KEY="your-base64-encoded-api-key-id:api-key-secret"
export KEY="${ES_API_KEY}"

# Optional: separate Kibana key (migrate scripts fall back to ES_API_KEY)
# export KIBANA_API_KEY=""

# --- Optional: username/password (Instruqt es3-api; API key preferred) ---
# export ES_USERNAME="admin"
# export ES_PASSWORD="your-generated-password"

# --- Optional: OpenTelemetry ingest (metrics-*/logs-*/traces-* for live panels) ---
# export WORKSHOP_OTLP_ENDPOINT="https://your-project-id.ingest.us-east-1.aws.elastic.cloud:443"
# export WORKSHOP_OTLP_AUTH_HEADER="ApiKey ${ES_API_KEY}"

# --- Optional: migration / validation ---
# export WORKSHOP_MIG_ES_VALIDATE="1"
# export WORKSHOP_SKIP_OTEL="1"
# export WORKSHOP_FORCE_OTEL_RESTART="1"

# --- Optional: tooling paths (Instruqt defaults) ---
# export MIG_TO_KBN_VENV="/opt/mig-to-kbn-venv"
# export WORKSHOP_PYTHON="/opt/workshop-venv/bin/python3"

# --- Optional: synthetic metrics (mig-to-kbn/scripts/setup_*_serverless_data.py) ---
# export DASHBOARD_YAML_DIR="${PWD}/build/mig-grafana/yaml"
# export DATA_HOURS="6"
# export INTERVAL_SEC="30"
